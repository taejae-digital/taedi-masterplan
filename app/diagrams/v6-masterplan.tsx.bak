const C = {
  dark: "#111", gray: "#666", light: "#999", line: "#ddd", bg: "#f9f9f9",
  red: "#8b2500", gold: "#8c6d1f", green: "#1a6b4a", blue: "#1a5276", navy: "#2c3e6b",
  commDk: "#0d4a30", comm: "#2d6a4f",
};

const tag = (color: string, text: string) => (
  <span style={{ display: "inline-block", padding: "2px 7px", borderRadius: 3, background: color, color: "#fff", fontSize: 11, fontWeight: 600, marginRight: 4 }}>{text}</span>
);

const s = {
  cell: { padding: "6px 10px", borderBottom: "1px solid #eee", verticalAlign: "top" as const, fontSize: 13, lineHeight: 1.5 },
  hcell: { padding: "5px 10px", borderBottom: "2px solid #333", fontSize: 11, fontWeight: 700 as const, textAlign: "left" as const },
  h2: (color: string) => ({ fontSize: 17, fontWeight: 800 as const, color, marginBottom: 6, paddingBottom: 4, borderBottom: `2px solid ${color}` }),
  h3: (color: string) => ({ fontSize: 14, fontWeight: 700 as const, color, marginBottom: 4, marginTop: 12 }),
  row: { display: "flex" as const, gap: 6, marginBottom: 3, fontSize: 13, lineHeight: 1.5 },
  stag: (color: string) => ({ fontWeight: 700 as const, color, fontSize: 11, minWidth: 52, flexShrink: 0 as const }),
};

function Page1() {
  return (
    <div style={{ pageBreakAfter: "always", maxHeight: "297mm", overflow: "hidden" as const }}>
      {/* 타이틀 */}
      <div style={{ borderBottom: `3px solid ${C.dark}`, paddingBottom: 10, marginBottom: 20 }}>
        <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-end" }}>
          <div>
            <h1 style={{ fontSize: 28, fontWeight: 800, margin: 0, lineHeight: 1.2 }}>신기술(디지털)이 초래할 위험성과 그 대책</h1>
            <div style={{ fontSize: 16, color: C.gold, fontWeight: 700, letterSpacing: 2, marginTop: 4 }}>MASTER PLAN</div>
          </div>
          <div style={{ textAlign: "right", fontSize: 13, color: C.light }}>
            <div style={{ fontWeight: 700, color: C.dark, fontSize: 14 }}>태재미래전략연구원</div>
            디지털 전환과 사회변혁팀 · 2026. 4. 7.
          </div>
        </div>
      </div>

      {/* 1행: 핵심 전제 + 역사적 패턴 */}
      <div style={{ display: "grid", gridTemplateColumns: "1fr 1.5fr", gap: 24, marginBottom: 18 }}>
        <div>
          <div style={s.h2("#333")}>핵심 전제</div>
          <div style={{ fontSize: 13, lineHeight: 1.8, color: "#333" }}>
            <p style={{ margin: "0 0 8px" }}>기술은 자유를 확장한다. AI는 <strong>정체성 실현의 자유</strong> — 남의 꿈이 아닌 자기 삶의 목적을 추구할 자유 — 를 연다.</p>
            <p style={{ margin: "0 0 8px" }}>그러나 확장된 자유는 기존 가치 체계와 충돌한다. 산업 시대의 가치 — <strong>"효율이 곧 가치, 정체성 실현은 사치"</strong> — 가 AI를 만나면, 인간 대체·권력 집중·군사화가 "합리적 결론"이 된다. 새로운 자유가 열릴 때마다 새로운 충돌이 일어난다. 이 충돌을 <strong>사전에 설계</strong>해야 한다.</p>
            <p style={{ margin: 0, color: C.red, fontWeight: 600 }}>설계가 앞서면 비용이 낮다. 늦으면 핵처럼 수습이 안 된다. 지금이 초기다.</p>
          </div>
        </div>
        <div>
          <div style={s.h2(C.navy)}>역사적 패턴 — 설계가 늦으면 대가가 크다</div>
          <table style={{ width: "100%", borderCollapse: "collapse", fontSize: 12.5, lineHeight: 1.5 }}>
            <thead><tr>
              <th style={s.hcell}>확장된 자유</th>
              <th style={s.hcell}>기존 가치의 저항</th>
              <th style={{ ...s.hcell, color: C.red }}>파괴적 전환</th>
              <th style={{ ...s.hcell, color: C.blue }}>안전한 전환</th>
              <th style={{ ...s.hcell, color: C.green }}>새 가치</th>
            </tr></thead>
            <tbody>
              <tr><td style={s.cell}>인쇄술 → 신앙의 자유</td><td style={s.cell}>교회 "지식은 사제의 것"</td><td style={{ ...s.cell, color: C.red }}>30년 전쟁</td><td style={s.cell}>—</td><td style={{ ...s.cell, color: C.green }}>신앙의 자유</td></tr>
              <tr><td style={s.cell}>증기기관 → 재산권의 자유</td><td style={s.cell}>구체제 "혈통이 권력"</td><td style={{ ...s.cell, color: C.red }}>프랑스 혁명</td><td style={{ ...s.cell, color: C.blue }}>영국 점진적 개혁</td><td style={{ ...s.cell, color: C.green }}>시민의 권리</td></tr>
              <tr><td style={s.cell}>대량생산 → 풍요의 자유</td><td style={s.cell}>자본 "시장이 조절"</td><td style={{ ...s.cell, color: C.red }}>대공황→파시즘</td><td style={{ ...s.cell, color: C.blue }}>뉴딜·살트셰바덴</td><td style={{ ...s.cell, color: C.green }}>사회적 권리</td></tr>
              <tr style={{ background: C.bg }}><td style={{ ...s.cell, fontWeight: 700 }}>AI → 누구나 전문가급</td><td style={s.cell}>"정체성 실현은 사치"</td><td style={{ ...s.cell, color: C.red }}>???</td><td style={{ ...s.cell, color: C.blue, fontWeight: 700 }}>안전한 가치 전환</td><td style={{ ...s.cell, color: C.green, fontWeight: 700 }}>정체성 실현권</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      {/* 2행: 불변→변화 + 구체적 위협 + 통제 */}
      <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr 1fr", gap: 20, marginBottom: 18 }}>
        <div>
          <div style={s.h2(C.dark)}>변하지 않는 것 → 변하는 것</div>
          <table style={{ width: "100%", borderCollapse: "collapse", fontSize: 12.5, lineHeight: 1.5 }}>
            <thead><tr>
              <th style={s.hcell}>불변</th>
              <th style={s.hcell}>연속체</th>
              <th style={s.hcell}>AI 시대</th>
            </tr></thead>
            <tbody>
              <tr><td style={{ ...s.cell, fontWeight: 700 }}>권력은 집중</td><td style={s.cell}>토지→자본→데이터</td><td style={{ ...s.cell, color: C.red }}>AI 독점, 무기화</td></tr>
              <tr><td style={{ ...s.cell, fontWeight: 700 }}>질서를 원함</td><td style={s.cell}>관습→법률→관료제</td><td style={{ ...s.cell, color: C.gold }}>알고리즘, 감시</td></tr>
              <tr><td style={{ ...s.cell, fontWeight: 700 }}>자유를 원함</td><td style={s.cell}>신앙→시민권→사회권</td><td style={{ ...s.cell, color: C.green }}>정체성 실현권</td></tr>
            </tbody>
          </table>
        </div>

        <div>
          <div style={s.h2(C.red)}>구체적 위협</div>
          <table style={{ width: "100%", borderCollapse: "collapse", fontSize: 12.5, lineHeight: 1.5 }}>
            <thead><tr>
              <th style={{ ...s.hcell, width: "13%" }}>긴급도</th>
              <th style={s.hcell}>위협</th>
              <th style={s.hcell}>왜 위험한가</th>
              <th style={{ ...s.hcell, width: "10%" }}>통제</th>
            </tr></thead>
            <tbody>
              <tr style={{ background: "#fff5f3" }}><td style={{ ...s.cell, fontWeight: 700, color: C.red }}>긴급</td><td style={{ ...s.cell, fontWeight: 600 }}>AI 생물무기</td><td style={s.cell}>대학원생도 설계 가능</td><td style={{ ...s.cell, fontWeight: 700, color: C.red }}>금지</td></tr>
              <tr style={{ background: "#fff5f3" }}><td style={{ ...s.cell, fontWeight: 700, color: C.red }}>긴급</td><td style={{ ...s.cell, fontWeight: 600 }}>사이버 WMD</td><td style={s.cell}>인프라 상호 파괴</td><td style={{ ...s.cell, fontWeight: 700, color: C.red }}>금지</td></tr>
              <tr style={{ background: "#fff5f3" }}><td style={{ ...s.cell, fontWeight: 700, color: C.red }}>긴급</td><td style={{ ...s.cell, fontWeight: 600 }}>핵AI화/자율살상</td><td style={s.cell}>인간 없는 핵 발사</td><td style={{ ...s.cell, fontWeight: 700, color: C.red }}>금지</td></tr>
              <tr style={{ background: "#fffdf5" }}><td style={{ ...s.cell, fontWeight: 700, color: C.gold }}>높음</td><td style={{ ...s.cell, fontWeight: 600 }}>AI 통제 상실</td><td style={s.cell}>자율적 목표 추구</td><td style={{ ...s.cell, fontWeight: 700, color: C.gold }}>승인</td></tr>
              <tr style={{ background: "#fffdf5" }}><td style={{ ...s.cell, fontWeight: 700, color: C.gold }}>진행중</td><td style={{ ...s.cell, fontWeight: 600 }}>감시/조작</td><td style={s.cell}>민주주의 침식</td><td style={{ ...s.cell, fontWeight: 700, color: C.gold }}>승인</td></tr>
              <tr><td style={{ ...s.cell, fontWeight: 700, color: C.green }}>기회</td><td style={{ ...s.cell, fontWeight: 600 }}>전문가급/노동/탈국가</td><td style={s.cell}>정체성 실현의 기반</td><td style={{ ...s.cell, fontWeight: 700, color: C.green }}>허용</td></tr>
            </tbody>
          </table>
        </div>

        <div>
          <div style={s.h2(C.blue)}>통제 프레임워크</div>
          <p style={{ fontSize: 13, color: "#333", margin: "0 0 10px", lineHeight: 1.6 }}>
            <strong>분류 기준 3가지:</strong> 비가역성 · 무차별성 · 통제불능
          </p>
          <div style={{ fontSize: 13, lineHeight: 1.7 }}>
            <div style={{ padding: "10px 12px", background: "#fef5f3", borderLeft: `4px solid ${C.red}`, marginBottom: 8 }}>
              <strong style={{ color: C.red }}>금지</strong> — 기준 2개+. 개발 자체를 막는다. 독립 검증 기구 사찰. 강대국 특권 배제.
            </div>
            <div style={{ padding: "10px 12px", background: "#fffdf5", borderLeft: `4px solid ${C.gold}`, marginBottom: 8 }}>
              <strong style={{ color: C.gold }}>승인</strong> — 기준 1개. 개발자가 안전 입증 후 배포. 부작용 기록·공개.
            </div>
            <div style={{ padding: "10px 12px", background: "#f0f7f4", borderLeft: `4px solid ${C.green}` }}>
              <strong style={{ color: C.green }}>허용</strong> — 해당 없음. 자유 개발 + 사후 모니터링.
            </div>
          </div>
        </div>
      </div>

      {/* 3행: AS-IS → TO-BE → TO-DO */}
      <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr 1fr", gap: 14 }}>
        <div style={{ padding: "12px 14px", background: "#f8f8f8", borderTop: `4px solid ${C.dark}` }}>
          <div style={{ fontSize: 15, fontWeight: 800, marginBottom: 8 }}>AS-IS — 현재</div>
          <div style={{ fontSize: 12.5, lineHeight: 1.6, color: "#444" }}>
            <div style={{ display: "flex", gap: 6, marginBottom: 3 }}><span style={{ fontWeight: 700, color: C.red, minWidth: 60, fontSize: 11 }}>핵심 5%</span><span><strong>효율=가치</strong> 체계가 AI를 파멸로 전환</span></div>
            <div style={{ display: "flex", gap: 6, marginBottom: 3 }}><span style={{ fontWeight: 700, color: C.gold, minWidth: 60, fontSize: 11 }}>주요 15%</span><span>개인: 남의 꿈을 위한 노동 / 공동체: 일자리·성장 제공</span></div>
            <div style={{ display: "flex", gap: 6 }}><span style={{ fontWeight: 700, color: C.light, minWidth: 60, fontSize: 11 }}>파생 80%</span><span style={{ color: C.gray }}>생존 위협·권력 집중·노동 위기·불평등·거버넌스 공백</span></div>
          </div>
        </div>
        <div style={{ padding: "12px 14px", background: "#f0f7f4", borderTop: `4px solid ${C.green}` }}>
          <div style={{ fontSize: 15, fontWeight: 800, color: C.green, marginBottom: 8 }}>TO-BE — 새로운 질서</div>
          <div style={{ fontSize: 12.5, lineHeight: 1.6, color: "#444" }}>
            <div style={{ display: "flex", gap: 6, marginBottom: 3 }}><span style={{ fontWeight: 700, color: C.green, minWidth: 60, fontSize: 11 }}>핵심 5%</span><span><strong>정체성 실현권</strong> — 참정권이 민주주의를 정의했듯</span></div>
            <div style={{ display: "flex", gap: 6, marginBottom: 3 }}><span style={{ fontWeight: 700, color: C.green, minWidth: 60, fontSize: 11 }}>주요 15%</span><span>개인: 자기 목적 추구 / 공동체: 정체성 실현 보장</span></div>
            <div style={{ display: "flex", gap: 6 }}><span style={{ fontWeight: 700, color: C.light, minWidth: 60, fontSize: 11 }}>파생 80%</span><span style={{ color: C.gray }}>금지선·균형·분배 재설계·경제 질서·거버넌스→세계 정부</span></div>
          </div>
        </div>
        <div style={{ padding: "12px 14px", background: "#f8f6f0", borderTop: `4px solid ${C.gold}` }}>
          <div style={{ fontSize: 15, fontWeight: 800, color: C.gold, marginBottom: 8 }}>TO-DO — 우리가 할 일</div>
          <div style={{ fontSize: 12.5, lineHeight: 1.6, color: "#444" }}>
            <div style={{ display: "flex", gap: 6, marginBottom: 3 }}><span style={{ fontWeight: 700, color: C.gold, minWidth: 60, fontSize: 11 }}>핵심 5%</span><span><strong>가치 전환</strong> — 위협 특정 + 통제. 가치가 서야 방향이 생긴다</span></div>
            <div style={{ display: "flex", gap: 6, marginBottom: 3 }}><span style={{ fontWeight: 700, color: C.gold, minWidth: 60, fontSize: 11 }}>주요 15%</span><span>① 위협 통제 ② 경제 질서 설계 ③ 거버넌스 구축</span></div>
            <div style={{ display: "flex", gap: 6 }}><span style={{ fontWeight: 700, color: C.light, minWidth: 60, fontSize: 11 }}>파생 80%</span><span style={{ color: C.gray }}>공동체 재편 + 정치적 실현 — 한국에서 먼저 만든다</span></div>
          </div>
        </div>
      </div>
    </div>
  );
}

function Page2() {
  return (
    <div style={{ maxHeight: "297mm", overflow: "hidden" as const }}>
      <div style={{ borderBottom: `2px solid ${C.dark}`, paddingBottom: 8, marginBottom: 18, marginTop: 30 }}>
        <h2 style={{ fontSize: 22, fontWeight: 800, margin: 0 }}>실행 계획 + 새로운 질서의 설계</h2>
        <div style={{ fontSize: 13, color: C.light }}>사회 변화 · 새로운 질서 · 2026년 목표 · 팀 역할</div>
      </div>

      {/* 1행: 사회 변화 (4계급 + 6공동체 + 소유권) */}
      <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr 1fr", gap: 20, marginBottom: 18 }}>
        <div>
          <div style={s.h2(C.red)}>계층 구조와 경제 활동의 변화</div>
          <table style={{ width: "100%", borderCollapse: "collapse", fontSize: 12.5, lineHeight: 1.5 }}>
            <thead><tr>
              <th style={s.hcell}>계층</th>
              <th style={s.hcell}>현재</th>
              <th style={s.hcell}>2050</th>
              <th style={s.hcell}>생산</th>
              <th style={s.hcell}>분배 (현재)</th>
              <th style={{ ...s.hcell, color: C.green }}>분배 (재설계)</th>
            </tr></thead>
            <tbody>
              <tr><td style={{ ...s.cell, fontWeight: 700 }}>리더 (AI 설계자)</td><td style={s.cell}>2%</td><td style={s.cell}>5%</td><td style={s.cell}>AI 인프라·모델 설계</td><td style={s.cell}>초과이윤 집중</td><td style={{ ...s.cell, color: C.green }}>초과이윤 누진세 + 공적 지분</td></tr>
              <tr><td style={{ ...s.cell, fontWeight: 700 }}>프로 (AI 도구 전문가)</td><td style={s.cell}>53%</td><td style={{ ...s.cell, color: C.red, fontWeight: 700 }}>25%</td><td style={s.cell}>AI 활용 고부가가치</td><td style={s.cell}>성과 기반 보상</td><td style={{ ...s.cell, color: C.green }}>성과 + 목적 기반 보상</td></tr>
              <tr><td style={{ ...s.cell, fontWeight: 700 }}>아마추어 (AI 의존)</td><td style={s.cell}>35%</td><td style={{ ...s.cell, color: C.red, fontWeight: 700 }}>65%</td><td style={s.cell}>AI 지시 따라 수행</td><td style={s.cell}>기본 보장 필요</td><td style={{ ...s.cell, color: C.green }}>기본소득 + 돌봄 인정소득</td></tr>
              <tr><td style={{ ...s.cell, fontWeight: 700 }}>소외 (접근 불가)</td><td style={s.cell}>10%</td><td style={s.cell}>5%</td><td style={s.cell}>AI 접근 불가</td><td style={s.cell}>공적 지원</td><td style={{ ...s.cell, color: C.green }}>AI 인프라 접근권 보장</td></tr>
            </tbody>
          </table>
          <p style={{ fontSize: 12, color: C.red, marginTop: 6, fontWeight: 500 }}>프로 53%→25%. 생산은 소수에 집중되고, 분배의 재설계가 불가피하다.</p>
        </div>

        <div>
          <div style={s.h2(C.comm)}>공동체 재편</div>
          <table style={{ width: "100%", borderCollapse: "collapse", fontSize: 13, lineHeight: 1.5 }}>
            <thead><tr>
              <th style={s.hcell}>공동체</th>
              <th style={s.hcell}>산업 시대</th>
              <th style={s.hcell}>디지털 시대</th>
            </tr></thead>
            <tbody>
              <tr><td style={{ ...s.cell, fontWeight: 700 }}>가정 (스마트홈)</td><td style={s.cell}>노동력 재생산</td><td style={s.cell}>정체성 허브, 창작·생산 단위</td></tr>
              <tr><td style={{ ...s.cell, fontWeight: 700 }}>이웃</td><td style={s.cell}>아파트 주민</td><td style={s.cell}>가치·취미 기반 선택 공동체</td></tr>
              <tr><td style={{ ...s.cell, fontWeight: 700 }}>마을</td><td style={s.cell}>행정구역</td><td style={s.cell}>도보권 공유시설</td></tr>
              <tr><td style={{ ...s.cell, fontWeight: 700 }}>도시</td><td style={s.cell}>일자리 있는 곳</td><td style={s.cell}>삶의 질 플랫폼, 직주근접</td></tr>
              <tr><td style={{ ...s.cell, fontWeight: 700 }}>국가</td><td style={s.cell}>모든 것 통제</td><td style={s.cell}>최소 개입 (국방·외교·재난)</td></tr>
              <tr><td style={{ ...s.cell, fontWeight: 700, color: C.commDk }}>세계 정부</td><td style={s.cell}>UN (무력)</td><td style={{ ...s.cell, fontWeight: 600 }}>화폐·금융·기술 규제·분쟁</td></tr>
            </tbody>
          </table>
        </div>

        <div>
          <div style={s.h2(C.gold)}>소유권의 변화</div>
          <div style={{ fontSize: 13, lineHeight: 1.8, color: "#333" }}>
            <div style={{ marginBottom: 6 }}><strong>부동산</strong> → 장소성 약화. 재택근무로 "어디 사는가"의 의미 변화.</div>
            <div style={{ marginBottom: 6 }}><strong>데이터</strong> → 정체성 데이터가 새로운 자산. 의료·교육·소비 데이터의 주권.</div>
            <div><strong>정체성</strong> → "나는 뭘 하는 사람인가"가 소유의 핵심. 직업이 아닌 목적으로 정의.</div>
          </div>
        </div>
      </div>

      {/* 2행: 새 질서 4박스 */}
      <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr 1fr 1fr", gap: 14, marginBottom: 18 }}>
        <div style={{ padding: "12px 14px", border: `1px solid ${C.line}`, borderTop: `4px solid ${C.red}` }}>
          <div style={{ fontSize: 15, fontWeight: 800, color: C.red, marginBottom: 8 }}>미중 합의 경로</div>
          <div style={{ fontSize: 13, lineHeight: 1.7 }}>
            <p style={{ margin: "0 0 8px", color: C.gray }}>이기든 지든, 이 문제를 해결하지 않으면 미래가 없다.</p>
            <div><strong style={{ color: C.red }}>최소선</strong> — 위협 공동 통제</div>
            <div><strong style={{ color: C.gold }}>구조</strong> — 블록화</div>
            <div><strong style={{ color: C.green }}>목표</strong> — 세계 의회 → 세계 정부</div>
          </div>
        </div>
        <div style={{ padding: "12px 14px", border: `1px solid ${C.line}`, borderTop: `4px solid ${C.navy}` }}>
          <div style={{ fontSize: 15, fontWeight: 800, color: C.navy, marginBottom: 8 }}>새로운 경제 질서</div>
          <div style={{ fontSize: 13, lineHeight: 1.7 }}>
            <div><strong>화폐</strong> — 달러 → 세계 정부 발행</div>
            <div><strong>분배</strong> — AI 이윤 환원 + 돌봄 인정소득</div>
            <div><strong>노동</strong> — 고용 → 목적 기반</div>
            <div><strong>가치</strong> — 효율 → 정체성 실현</div>
          </div>
        </div>
        <div style={{ padding: "12px 14px", border: `1px solid ${C.line}`, borderTop: `4px solid ${C.gold}` }}>
          <div style={{ fontSize: 15, fontWeight: 800, color: C.gold, marginBottom: 8 }}>거버넌스</div>
          <div style={{ fontSize: 13, lineHeight: 1.7 }}>
            <div><strong>세계 의회</strong> — 상원(국가) + 하원(시민 직접)</div>
            <div><strong>AI 통제 기구</strong> — 독립 검증·사찰</div>
            <div><strong>국가·도시 의회</strong> — 분산 거버넌스</div>
            <div><strong>강제력</strong> — 초다수결. 거부권 없음</div>
          </div>
        </div>
        <div style={{ padding: "12px 14px", border: `1px solid ${C.line}`, borderTop: `4px solid ${C.green}` }}>
          <div style={{ fontSize: 15, fontWeight: 800, color: C.green, marginBottom: 8 }}>정치적 실현</div>
          <div style={{ fontSize: 13, lineHeight: 1.7 }}>
            <p style={{ margin: "0 0 8px" }}>패권의 최전선에서 합의의 최전선으로.</p>
            <p style={{ margin: "0 0 8px", fontWeight: 700, color: C.gold }}>"더 큰 자유" — 위험은 함께 막고, 자유는 최대한 누린다.</p>
            <p style={{ margin: 0 }}>새로운 질서의 모델을 한국에서 먼저 만든다.</p>
          </div>
        </div>
      </div>

      {/* 3행: 실행 일정 + 팀 + 성과 */}
      <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr 1fr", gap: 20 }}>
        <div>
          <div style={s.h2(C.navy)}>2026년 실행 일정</div>
          <table style={{ width: "100%", borderCollapse: "collapse", fontSize: 13, lineHeight: 1.5 }}>
            <thead><tr>
              <th style={{ ...s.hcell, width: "14%" }}>시기</th>
              <th style={s.hcell}>실행 내용</th>
              <th style={{ ...s.hcell, width: "28%" }}>산출물</th>
            </tr></thead>
            <tbody>
              {[
                ["4월", "디지털 위협 특정 워크샵 (4/7)", "위협 목록 + 분류 기준"],
                ["5~6월", "통제 방안 + 경제 질서 연구", "통합 보고서 초안"],
                ["7~8월", "국제 자문단 구성·검토", "보고서 보완"],
                ["9~10월", "단행본 집필", "단행본 출간"],
                ["11~12월", "서울 컨퍼런스 + 정치적 실현", "공론화·정치화"],
              ].map(([t, c, o]) => (
                <tr key={t as string}><td style={{ ...s.cell, fontWeight: 700 }}>{t}</td><td style={s.cell}>{c}</td><td style={s.cell}>{o}</td></tr>
              ))}
            </tbody>
          </table>
        </div>

        <div>
          <div style={s.h2(C.dark)}>팀 역할</div>
          <table style={{ width: "100%", borderCollapse: "collapse", fontSize: 13, lineHeight: 1.5 }}>
            <tbody>
              {[
                ["유호현 (팀장)", "총괄 · 경제 질서 · 정치적 실현"],
                ["윤준영", "AI 무기 · 미중 패권 · 국제 레짐"],
                ["김수연", "존엄 위기 · 노동/분배 · 공동체"],
                ["이규환", "빅테크 · AI 환경 · 디지털 권리"],
              ].map(([n, r]) => (
                <tr key={n as string}><td style={{ ...s.cell, fontWeight: 700, width: "36%" }}>{n}</td><td style={s.cell}>{r}</td></tr>
              ))}
            </tbody>
          </table>
        </div>

        <div>
          <div style={s.h2(C.green)}>2026년 성과 목표</div>
          <div style={{ fontSize: 13, lineHeight: 1.7 }}>
            {[
              [C.red, "위협 목록 완성 + 분류 기준"],
              [C.blue, "통제 방안 초안 (금지/승인/허용)"],
              [C.navy, "경제 질서 청사진"],
              [C.gold, "단행본 출간"],
              [C.green, "정치적 실현 — 한국에서 먼저"],
            ].map(([c, t], i) => (
              <div key={i} style={{ padding: "8px 10px", background: C.bg, borderLeft: `4px solid ${c}`, marginBottom: 6 }}>{t}</div>
            ))}
          </div>
        </div>
      </div>
    </div>
  );
}

export function V6MasterPlan() {
  return (
    <div style={{ width: 1500, margin: "0 auto", background: "#fff", padding: "24px 40px" }}>
      <style>{`@media print { @page { size: A3 landscape; margin: 10mm; } }`}</style>
      <Page1 />
      <Page2 />
    </div>
  );
}
