\uc0\u49324 \u54924 \u44032  \u48148 \u45076  \u46412 , \u47924 \u50631 \u51060  \u47676 \u51200  \u48148 \u45068 \u45716 \u44032 ?\
\
\uc0\u50669 \u49324 \u47484  \u48372 \u47732  \u45813 \u51060  \u51080 \u45796 . \u50616 \u51228 \u45208  \u44060 \u51064 \u51060  \u47676 \u51200  \u48148 \u45068 \u50632 \u45796 . \u44592 \u49696 \u51060  \u44060 \u51064 \u51032  \u50669 \u47049 \u51012  \u54869 \u51109 \u54616 \u47732 , \u44060 \u51064 \u51060  \u45804 \u46972 \u51648 \u44256 , \u44060 \u51064 \u44284  \u44060 \u51064  \u49324 \u51060 \u51032  \u44288 \u44228 \u44032  \u45804 \u46972 \u51648 \u44256 , \u44536  \u44288 \u44228 \u44032  \u47784 \u50668  \u47564 \u46304  \u44277 \u46041 \u52404 \u51032  \u51656 \u49436 \u44032  \u45804 \u46972 \u51276 \u45796 . \u44221 \u51228  \u51656 \u49436 \u44032  \u48148 \u45068 \u44256 , \u51221 \u52824  \u51656 \u49436 \u44032  \u48148 \u45068 \u44256 , \u47560 \u51648 \u47561 \u51004 \u47196  \u44536  \u51656 \u49436 \u47484  \u47749 \u47928 \u54868 \u54616 \u45716  \u51228 \u46020 \u50752  \u44144 \u48260 \u45324 \u49828 \u44032  \u46244 \u46384 \u46992 \u45796 . \u51060  \u49692 \u49436 \u45716  \u54620  \u48264 \u46020  \u48148 \u45072  \u51201 \u51060  \u50630 \u45796 .\
\
\uc0\u51060  \u44544 \u51008  \u44536  \u49692 \u49436 \u47484  \u46384 \u47480 \u45796 . \u46356 \u51648 \u53560  \u44592 \u49696 \u51060  \u44060 \u51064 \u51012  \u50612 \u46523 \u44172  \u48148 \u44984 \u45716 \u51648 \u48512 \u53552  \u52636 \u48156 \u54616 \u50668 , \u44060 \u51064 \u44284  \u44277 \u46041 \u52404 \u51032  \u44288 \u44228 \u44032  \u50612 \u46523 \u44172  \u51116 \u54200 \u46104 \u45716 \u51648 \u47484  \u44144 \u52824 \u44256 , \u44221 \u51228  \u51656 \u49436 \u51032  \u48320 \u46041 \u51012  \u44221 \u50976 \u54616 \u50668 , \u49324 \u54924  \u51656 \u49436  \u51204 \u48152 \u51032  \u51204 \u54872 \u50640  \u46020 \u45804 \u54616 \u44256 , \u44536  \u51204 \u54872 \u51060  \u52488 \u47000 \u54616 \u45716  \u50948 \u54744 \u51012  \u51649 \u49884 \u54620  \u46244 , \u48708 \u47196 \u49548  \u44144 \u48260 \u45324 \u49828 \u51032  \u51656 \u47928 \u50640  \u51060 \u47480 \u45796 . \u44208 \u47200 \u51012  \u47676 \u51200  \u47568 \u54616 \u45716  \u44163 \u51060  \u50500 \u45768 \u46972 , \u44208 \u47200 \u50640  \u51060 \u47476 \u45716  \u49324 \u44256 \u51032  \u44221 \u47196 \u47484  \u54632 \u44760  \u44151 \u45716  \u44163 \u51060  \u51060  \u44544 \u51032  \u47785 \u51201 \u51060 \u45796 .\
