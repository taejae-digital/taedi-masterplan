2\uc0\u51109 : \u44060 \u51064 \u51032  \u48320 \u54868  \'97 \u49334 , \u50669 \u47049 , \u49373 \u50528 \u51452 \u44592 \
\
\uc0\u51060  \u51204 \u54872 \u51032  \u52636 \u48156 \u51216 \u51008  \u44144 \u49884 \u51201  \u51656 \u49436 \u44032  \u50500 \u45768 \u46972  \u54620  \u49324 \u46988 \u51032  \u49334 \u51060 \u45796 . AI\u44032  \u44060 \u51064 \u51032  \u51068 \u49345 \u51012  \u50612 \u46523 \u44172  \u48148 \u44984 \u45716 \u51648 \u47484  \u47676 \u51200  \u51060 \u54644 \u54616 \u51648  \u50506 \u51004 \u47732 , \u44536  \u51060 \u54980 \u51032  \u47784 \u46304  \u48516 \u49437 \u51008  \u52628 \u49345 \u50640  \u47672 \u47928 \u45796 .\
\
\uc0\u50669 \u47049 \u51032  \u48320 \u54868 . \u47560 \u52992 \u53552  \u54620  \u47749 \u51060  AI\u47196  \u45936 \u51060 \u53552  \u48516 \u49437 , \u52852 \u54588  \u51089 \u49457 , \u49884 \u51109  \u51312 \u49324 \u47484  \u54616 \u47336  \u47564 \u50640  \u50756 \u49457 \u54620 \u45796 . 10\u45380  \u51204 \u51060 \u46972 \u47732  \u45936 \u51060 \u53552  \u48516 \u49437 \u44032 , \u52852 \u54588 \u46972 \u51060 \u53552 , \u47532 \u49436 \u52376  \u49464  \u47749 \u51060  \u51068 \u51452 \u51068  \u44152 \u47540  \u51089 \u50629 \u51060 \u45796 . \u49888 \u51077  \u48320 \u54840 \u49324 \u44032  AI\u47196  \u54032 \u47168 \u47484  \u44160 \u53664 \u54616 \u47732 , 5\u45380  \u52264  \u49440 \u48176 \u44032  \u51060 \u53952  \u44152 \u47140  \u54624  \u51089 \u50629 \u51012  \u48152 \u45208 \u51208 \u50640  \u45149 \u45240 \u45796 . \u51032 \u45824 \u49373 \u51060  AI\u51032  \u46020 \u50880 \u51004 \u47196  \u50689 \u49345  \u54032 \u46021  \u54984 \u47144 \u51012  \u48155 \u51004 \u47732 , \u51204 \u44277 \u51032  \u49688 \u47144  \u44592 \u44036 \u50640  \u52629 \u51201 \u54624  \u44221 \u54744 \u51012  \u54617 \u48512  \u44284 \u51221 \u50640 \u49436  \u54869 \u48372 \u54624  \u49688  \u51080 \u45796 . \u51060 \u44163 \u51008  \u45800 \u49692 \u54620  \u54952 \u50984  \u54693 \u49345 \u51060  \u50500 \u45768 \u45796 . \u51652 \u51077 \u51109 \u48317 \u51032  \u44396 \u51312 \u51201  \u54616 \u46973 \u51060 \u45796 . \u53945 \u51221  \u50669 \u47049 \u50640  \u46020 \u45804 \u54616 \u44592  \u50948 \u54644  \u54596 \u50836 \u54664 \u45912  \u49884 \u44036 , \u48708 \u50857 , \u51228 \u46020 \u51201  \u44221 \u47196 \u44032  \u44540 \u48376 \u51201 \u51004 \u47196  \u51687 \u50500 \u51648 \u44256  \u51080 \u45796 .\
\
\uc0\u51088 \u50984 \u49457 \u51032  \u48320 \u54868 . \u50669 \u47049 \u51060  \u54869 \u51109 \u46108  \u44060 \u51064 \u51008  \u45908  \u53360  \u51088 \u50984 \u49457 \u51012  \u50836 \u44396 \u54616 \u44172  \u46108 \u45796 . \u51060 \u44163 \u51008  \u50837 \u47581 \u51060  \u50500 \u45768 \u46972  \u45436 \u47532 \u51201  \u44480 \u44208 \u51060 \u45796 . AI\u47196  \u54016 \u51109 \u48372 \u45796  \u51221 \u48128 \u54620  \u48516 \u49437 \u51012  \u50756 \u49457 \u54620  \u54016 \u50896 \u51008  \u51088 \u50672 \u49828 \u47101 \u44172  \u47931 \u45716 \u45796  \'97 "\u45236 \u44032  \u51649 \u51217  \u54032 \u45800 \u54616 \u47732  \u50504  \u46104 \u45716 \u44032 ?" \u51060 \u44163 \u51008  \u48520 \u47564 \u51060  \u50500 \u45768 \u45796 . \u50669 \u47049 \u51060  \u54869 \u51109 \u46108  \u44060 \u51064 \u51060  \u54596 \u50672 \u51201 \u51004 \u47196  \u46020 \u45804 \u54616 \u45716  \u51656 \u47928 \u51060 \u45796 . \u51088 \u50984 \u49457 \u51060  \u54869 \u45824 \u46104 \u47732  \u44536 \u50640  \u49345 \u51025 \u54616 \u45716  \u52293 \u51076 \u46020  \u46384 \u46972 \u50728 \u45796 . \u54032 \u45800 \u51032  \u44428 \u54620 \u51060  \u44060 \u51064 \u50640 \u44172  \u51060 \u46041 \u54616 \u47732 , \u54032 \u45800 \u51032  \u44208 \u44284 \u50640  \u45824 \u54620  \u52293 \u47924 \u46020  \u44060 \u51064 \u50640 \u44172  \u51060 \u46041 \u54620 \u45796 . \u51088 \u50976 \u50752  \u52293 \u51076 \u51008  \u48516 \u47532 \u54624  \u49688  \u50630 \u45796 .\
\
\uc0\u49334 \u51032  \u44396 \u51312  \u48320 \u54868 . AI\u45716  \u44060 \u51064 \u51032  \u50669 \u47049 \u47564 \u51060  \u50500 \u45768 \u46972  \u49334 \u51032  \u44396 \u51312  \u51088 \u52404 \u47484  \u48148 \u44988 \u45796 . \u49328 \u50629 \u54868  \u49884 \u45824 \u51032  \u49334 \u51008  \u44368 \u50977 -\u45432 \u46041 -\u51008 \u53748 \u46972 \u45716  3\u45800 \u44228  \u49373 \u50528 \u51452 \u44592 \u47196  \u49444 \u44228 \u46104 \u50612  \u51080 \u50632 \u45796 . 20\u45824 \u44620 \u51648  \u48176 \u50864 \u44256 , 60\u45824 \u44620 \u51648  \u51068 \u54616 \u44256 , \u51060 \u54980 \u50640  \u49776 \u45796 . \u51060  \u44396 \u51312 \u45716  \u45432 \u46041  \u49884 \u51109 \u51032  \u50836 \u44396 \u50640  \u52572 \u51201 \u54868 \u46108  \u44163 \u51060 \u50632 \u45796 . \u44277 \u51109 \u51008  \u54364 \u51456 \u54868 \u46108  \u44592 \u49696 \u51012  \u44032 \u51652  \u45432 \u46041 \u47141 \u51012  \u54596 \u50836 \u47196  \u54664 \u44256 , \u44368 \u50977  \u52404 \u44228 \u45716  \u44536 \u44163 \u51012  \u44277 \u44553 \u54616 \u44592  \u50948 \u54644  \u49444 \u44228 \u46104 \u50632 \u45796 .\
\
AI \uc0\u49884 \u45824 \u50640  \u51060  \u44396 \u51312 \u45716  \u50976 \u51648 \u46104 \u44592  \u50612 \u47157 \u45796 . \u53945 \u51221  \u44592 \u49696 \u51032  \u50976 \u54952  \u44592 \u44036 \u51060  \u44537 \u51201 \u51004 \u47196  \u45800 \u52629 \u46104 \u44592  \u46412 \u47928 \u51060 \u45796 . 10\u45380 \u44036  \u52629 \u51201 \u54620  \u51204 \u47928 \u49457 \u51060  AI \u47784 \u45944  \u54616 \u45208 \u51032  \u46321 \u51109 \u51004 \u47196  \u48276 \u50857 \u54868 \u46104 \u45716  \u54872 \u44221 \u50640 \u49436 , \u54620  \u48264 \u51032  \u44368 \u50977 \u51004 \u47196  40\u45380 \u51012  \u48260 \u54000 \u45716  \u49373 \u50528 \u51452 \u44592  \u47784 \u45944 \u51008  \u51089 \u46041 \u54616 \u51648  \u50506 \u45716 \u45796 . \u45824 \u49888  \u54617 \u49845 \u44284  \u45432 \u46041 \u44284  \u51116 \u54617 \u49845 \u51060  \u48152 \u48373 \u51201 \u51004 \u47196  \u49692 \u54872 \u54616 \u45716  \u44396 \u51312 \u44032  \u46108 \u45796 . 50\u45824 \u50640  \u49352 \u47196 \u50868  \u48516 \u50556 \u47484  \u54617 \u49845 \u54616 \u44256 , 30\u45824 \u50640  \u50504 \u49885 \u44592 \u47484  \u44054 \u44256 , 70\u45824 \u50640  \u44221 \u54744  \u44592 \u48152 \u51032  \u54032 \u45800  \u50669 \u54624 \u47196  \u48373 \u44480 \u54616 \u45716  \u44163 \u51060  \u48708 \u51221 \u49345 \u51060  \u50500 \u45768 \u46972  \u54633 \u47532 \u51201  \u49440 \u53469 \u51060  \u46104 \u45716  \u49884 \u45824 \u45796 .\
\
\uc0\u44148 \u44053 \u44284  \u49688 \u47749 \u51032  \u48320 \u54868 . AI \u44592 \u48152  \u51032 \u47308  \u51652 \u45800 , \u47582 \u52644 \u54805  \u52824 \u47308 , \u50976 \u51204 \u52404  \u48516 \u49437 \u51032  \u48156 \u51204 \u51008  \u44060 \u51064 \u51060  \u51088 \u49888 \u51032  \u44148 \u44053 \u51012  \u44288 \u47532 \u54616 \u45716  \u50669 \u47049 \u51012  \u54869 \u51109 \u54620 \u45796 . \u51032 \u49324 \u50640 \u44172  \u51204 \u51201 \u51004 \u47196  \u50948 \u51076 \u54664 \u45912  \u44148 \u44053  \u54032 \u45800 \u51032  \u49345 \u45817  \u48512 \u48516 \u51060  \u44060 \u51064 \u50640 \u44172  \u46028 \u50500 \u50728 \u45796 . \u46041 \u49884 \u50640  \u54217 \u44512  \u49688 \u47749 \u51032  \u50672 \u51109 \u51008  \u49373 \u50528 \u51452 \u44592  \u51116 \u49444 \u44228 \u47484  \u45908 \u50865  \u48520 \u44032 \u54588 \u54616 \u44172  \u47564 \u46304 \u45796 . 100\u49464  \u49884 \u45824 \u50640  20\u45824 \u50640  \u45236 \u47536  \u51649 \u50629  \u49440 \u53469 \u51060  80\u45380 \u51012  \u44508 \u51221 \u54616 \u45716  \u44163 \u51008  \u44396 \u51312 \u51201 \u51004 \u47196  \u48520 \u54633 \u47532 \u54616 \u45796 .\
\
\uc0\u51221 \u52404 \u49457 \u51032  \u48320 \u54868 . \u49328 \u50629 \u54868  \u49884 \u45824 \u50640  \u44060 \u51064 \u51032  \u51221 \u52404 \u49457 \u51008  \u51649 \u50629 \u44284  \u44053 \u54616 \u44172  \u44208 \u54633 \u46104 \u50612  \u51080 \u50632 \u45796 . "\u47924 \u49832  \u51068  \u54616 \u49464 \u50836 ?"\u46972 \u45716  \u51656 \u47928 \u51060  \u44263  "\u45817 \u49888 \u51008  \u45572 \u44396 \u51077 \u45768 \u44620 ?"\u51032  \u45824 \u50857 \u51060 \u50632 \u45796 . AI\u44032  \u51649 \u50629  \u44396 \u51312 \u47484  \u51116 \u54200 \u54616 \u47732 , \u51060  \u44208 \u54633 \u51060  \u45712 \u49832 \u54644 \u51652 \u45796 . \u51649 \u50629 \u51060  \u51221 \u52404 \u49457 \u51032  \u51204 \u48512 \u44032  \u50500 \u45772  \u49884 \u45824 \u50640 , \u44060 \u51064 \u51008  \u51116 \u45733 , \u44288 \u44228 , \u44032 \u52824 \u44288 \u50640  \u44592 \u48152 \u54616 \u50668  \u51221 \u52404 \u49457 \u51012  \u44396 \u49457 \u54624  \u51088 \u50976 \u47484  \u50619 \u45716 \u45796 . \u46041 \u49884 \u50640 , \u44536  \u51221 \u52404 \u49457 \u51012  \u49828 \u49828 \u47196  \u44396 \u49457 \u54644 \u50556  \u54616 \u45716  \u48512 \u45812 \u46020  \u50504 \u44172  \u46108 \u45796 .\
\
\uc0\u51060  \u47784 \u46304  \u48320 \u54868 \u47484  \u44288 \u53685 \u54616 \u45716  \u54645 \u49900 \u51008  \u54616 \u45208 \u45796 . \u44060 \u51064 \u51032  \u49334 \u50640 \u49436  \u50808 \u48512  \u44592 \u44288 \u50640  \u50948 \u51076 \u54664 \u45912  \u54032 \u45800 \u51032  \u48276 \u50948 \u44032  \u52629 \u49548 \u46104 \u44256  \u51080 \u45796 . \u44368 \u50977  \u44592 \u44288 \u51060  \u46021 \u51216 \u54664 \u45912  \u54617 \u49845  \u44221 \u47196 , \u51032 \u47308  \u44592 \u44288 \u51060  \u46021 \u51216 \u54664 \u45912  \u44148 \u44053  \u54032 \u45800 , \u44592 \u50629 \u51060  \u46021 \u51216 \u54664 \u45912  \u44221 \u47141  \u49444 \u44228  \'97 \u51060  \u47784 \u46304  \u50689 \u50669 \u50640 \u49436  \u44060 \u51064 \u51032  \u51088 \u50984 \u51201  \u54032 \u45800  \u44032 \u45733 \u49457 \u51060  \u54869 \u45824 \u46104 \u44256  \u51080 \u45796 . \u51060 \u44163 \u51060  \u45796 \u51020  \u51109 \u50640 \u49436  \u45436 \u54624  \u44277 \u46041 \u52404  \u51656 \u49436  \u51116 \u54200 \u51032  \u52636 \u48156 \u51216 \u51060 \u45796 .\
\
\
\
\
3\uc0\u51109 : \u44060 \u51064 \u44284  \u44277 \u46041 \u52404 \u51032  \u44288 \u44228  \u48320 \u54868 \
\
\uc0\u44060 \u51064 \u51008  \u44277 \u46041 \u52404 \u51032  \u52636 \u48156 \u51216 \u51060 \u51088  \u44032 \u51109  \u44592 \u48376 \u51060  \u46104 \u45716  \u45800 \u50948 \u45796 . \u44277 \u46041 \u52404 \u45716  \u44032 \u51221  \u8594  \u51060 \u50883  \u8594  \u47560 \u51012  \u8594  \u46020 \u49884  \u8594  \u44397 \u44032  \u8594  \u44544 \u47196 \u48268  \u8594  \u49373 \u53468 \u44228 \u47196  \u44396 \u49457 \u46108 \u45796 . \u44277 \u46041 \u52404 \u45716  \u44256 \u51221 \u46108  \u49892 \u52404 \u44032  \u50500 \u45768 \u46972  \u44032 \u52824 \u50752  \u51060 \u51061 \u51012  \u44277 \u50976 \u54616 \u45716  \u44288 \u44228 \u51032  \u52404 \u44228 \u45796 .\
\
\uc0\u44277 \u46041 \u52404 \u51032  \u51316 \u51116  \u51060 \u50976 \u45716  \u44060 \u51064 \u51060  \u54844 \u51088  \u44048 \u45817 \u54624  \u49688  \u50630 \u45716  \u47928 \u51228 \u47484  \u54632 \u44760  \u54644 \u44208 \u54616 \u45716  \u45936  \u51080 \u45796 . \u44060 \u51064 \u51008  \u50504 \u51204 \u44284  \u44148 \u44053 \u51012  \u52572 \u50864 \u49440 \u51004 \u47196  \u52628 \u44396 \u54616 \u45716  \u51316 \u51116 \u45796 . \u54844 \u51088 \u49436  \u44536 \u44163 \u51012  \u54869 \u48372 \u54624  \u49688  \u50630 \u51012  \u46412 , \u44060 \u51064 \u51008  \u44277 \u46041 \u52404 \u50640  \u44428 \u54620 \u51012  \u50948 \u51076 \u54620 \u45796 . \u51060  \u50948 \u51076 \u51008  \u47924 \u54620 \u54616 \u51648  \u50506 \u45796 . \u44277 \u44277  \u51656 \u49436  \u50976 \u51648 \u46972 \u45716  \u51228 \u54620 \u46108  \u47785 \u51201 \u51012  \u50948 \u54620  \u44163 \u51060 \u47728 , \u47785 \u51201 \u51060  \u45804 \u49457 \u46104 \u47732  \u44428 \u54620 \u46020  \u46028 \u50500 \u50752 \u50556  \u54620 \u45796 .\
\
\uc0\u44536 \u47084 \u45208  \u49328 \u50629 \u54868  \u49884 \u45824 \u50640  \u51060  \u50948 \u51076 \u51060  \u44060 \u51064 \u51032  \u51088 \u50976 \u47484  \u52840 \u54644 \u54616 \u45716  \u49688 \u51456 \u51004 \u47196  \u54869 \u51109 \u46104 \u50632 \u45796 . \u50780  \u44536 \u47020 \u45716 \u44032 ? \u49328 \u50629  \u44221 \u51228 \u44032  \u50836 \u44396 \u54616 \u45716  \u44508 \u47784 \u50752  \u54364 \u51456 \u54868  \u46412 \u47928 \u51060 \u50632 \u45796 . \u44277 \u51109 \u51008  \u45824 \u44508 \u47784  \u45432 \u46041 \u47141 \u51032  \u51312 \u51649 \u51201  \u53804 \u51077 \u51012  \u54596 \u50836 \u47196  \u54664 \u44256 , \u44397 \u44032 \u45716  \u44536  \u45432 \u46041 \u47141 \u51012  \u44368 \u50977 \u54616 \u44256 , \u46041 \u50896 \u54616 \u44256 , \u53685 \u51228 \u54616 \u45716  \u50669 \u54624 \u51012  \u47585 \u50520 \u45796 . \u51669 \u48337 \u51228 , \u54364 \u51456 \u54868 \u46108  \u44368 \u50977  \u44284 \u51221 , \u45432 \u46041 \u48277 , \u49324 \u54924 \u48372 \u54744  \'97 \u51060  \u47784 \u46304  \u51228 \u46020 \u45716  \u49328 \u50629  \u44221 \u51228 \u51032  \u54596 \u50836 \u50640  \u51032 \u54644  \u49444 \u44228 \u46104 \u50632 \u45796 . \u44060 \u51064 \u51032  \u51088 \u50984 \u49457 \u48372 \u45796  \u51665 \u45800 \u51032  \u54952 \u50984 \u49457 \u51060  \u50864 \u49440 \u49884 \u46104 \u45716  \u44396 \u51312 \u50688 \u45796 .\
\
AI \uc0\u49884 \u45824 \u50640  \u51060  \u44396 \u51312 \u51032  \u51204 \u51228 \u44032  \u47924 \u45320 \u51652 \u45796 . \u45824 \u44508 \u47784  \u51312 \u51649 \u51201  \u53804 \u51077 \u51060  \u50500 \u45768 \u46972  \u49548 \u44508 \u47784  \u44256 \u50669 \u47049  \u45800 \u50948 \u44032  \u49373 \u49328 \u51032  \u51473 \u49900 \u51060  \u46104 \u47732 , \u44397 \u44032 \u44032  \u45432 \u46041 \u47141 \u51012  \u51312 \u51649 \u54616 \u44256  \u53685 \u51228 \u54644 \u50556  \u54624  \u54596 \u50836 \u44032  \u51460 \u50612 \u46304 \u45796 . \u44368 \u50977 \u46020  \u47560 \u52268 \u44032 \u51648 \u45796 . \u54364 \u51456 \u54868 \u46108  \u52964 \u47532 \u53336 \u47100 \u51004 \u47196  \u46041 \u51656 \u51201  \u45432 \u46041 \u47141 \u51012  \u45824 \u47049  \u49373 \u49328 \u54644 \u50556  \u54624  \u51060 \u50976 \u44032  \u49324 \u46972 \u51648 \u47732 , \u44368 \u50977 \u50640  \u45824 \u54620  \u44060 \u51064 \u51032  \u51088 \u50984 \u51201  \u49440 \u53469  \u48276 \u50948 \u44032  \u54869 \u45824 \u46108 \u45796 .\
\
\uc0\u50948 \u51076  \u44396 \u51312 \u45716  \u50500 \u47000 \u47196  \u45236 \u47140 \u50728 \u45796 . \u44060 \u51064 \u44284  \u44032 \u51221 \u51060  \u51649 \u51217  \u52376 \u47532 \u54616 \u45716  \u50689 \u50669 \u51060  \u54869 \u45824 \u46108 \u45796 . AI\u44032  \u48277 \u47456  \u51088 \u47928 , \u51116 \u47924  \u49444 \u44228 , \u44148 \u44053  \u44288 \u47532 \u51032  \u51652 \u51077 \u51109 \u48317 \u51012  \u45230 \u52628 \u47732 , \u51060  \u50689 \u50669 \u46308 \u50640 \u49436  \u51204 \u47928  \u44592 \u44288 \u50640  \u45824 \u54620  \u51032 \u51316 \u51060  \u51460 \u50612 \u46304 \u45796 . \u51060 \u50883 \u44284  \u47560 \u51012  \u45800 \u50948 \u51032  \u51088 \u52824 \u44032  \u45796 \u49884  \u51032 \u48120 \u47484  \u44054 \u44172  \u46108 \u45796 . \u46020 \u49884 \u44032  \u49352 \u47196 \u50868  \u49892 \u54744  \u45800 \u50948 \u44032  \u46108 \u45796 . \u44397 \u44032 \u45716  \u44397 \u48169 , \u50808 \u44368 , \u51116 \u45212  \u45824 \u51025 \u52376 \u47100  \u44060 \u51064 \u44284  \u46020 \u49884 \u44032  \u54844 \u51088  \u44048 \u45817 \u54624  \u49688  \u50630 \u45716  \u47928 \u51228 \u50640  \u51665 \u51473 \u54616 \u44256 , \u49464 \u44228 \u45716  AI \u44144 \u48260 \u45324 \u49828 , \u44592 \u54980  \u50948 \u44592 \u52376 \u47100  \u44397 \u44032 \u44032  \u54844 \u51088  \u54400  \u49688  \u50630 \u45716  \u47928 \u51228 \u47564  \u45796 \u47340 \u45796 .\
\
\uc0\u50724 \u54536 \u49548 \u49828  \u49373 \u53468 \u44228 \u45716  \u51060 \u48120  \u51060  \u44396 \u51312 \u51032  \u50896 \u54805 \u51012  \u48372 \u50668 \u51456 \u45796 . \u47532 \u45573 \u49828 \u45716  \u49688 \u52380  \u47749 \u51060  \u50948 \u44228  \u50630 \u51060  \u44592 \u50668 \u54616 \u51648 \u47564 , \u44592 \u50668 \u51032  \u51656 \u51060  \u51088 \u50672 \u49828 \u47101 \u44172  \u44428 \u50948 \u47484  \u47564 \u46304 \u45796 . \u51649 \u52293 \u51060  \u50500 \u45768 \u46972  \u44592 \u50668 \u44032  \u44428 \u50948 \u51032  \u44540 \u44144 \u44032  \u46108 \u45796 . \u50948 \u53412 \u54588 \u46356 \u50500 \u46020  \u47560 \u52268 \u44032 \u51648 \u45796 . \u51473 \u50521  \u54200 \u51665  \u50948 \u50896 \u54924 \u44032  \u50500 \u45768 \u46972  \u52280 \u50668 \u51088 \u46308 \u51032  \u48152 \u48373 \u51201 \u51064  \u44160 \u51613 \u51060  \u54408 \u51656 \u51012  \u45812 \u48372 \u54620 \u45796 . \u51060 \u44163 \u51008  \u54032 \u45800 \u44284  \u44592 \u50668 \u51032  \u48708 \u45824 \u52845 \u49457 \u51060  \u54644 \u49548 \u46108  \u54872 \u44221 \u50640 \u49436  \u51088 \u50672 \u48156 \u49373 \u54616 \u45716  \u51656 \u49436 \u51032  \u54805 \u53468 \u45796 .\
\
\uc0\u46041 \u49884 \u50640  \u44036 \u44284 \u54644 \u49436 \u45716  \u50504  \u46104 \u45716  \u50669 \u49444 \u51060  \u51080 \u45796 . AI\u44032  \u54952 \u50984 \u51201 \u51004 \u47196  \u45824 \u52404 \u54624  \u49688  \u50630 \u45716  \u50689 \u50669 \u51060  \u51316 \u51116 \u54616 \u47728 , \u44536  \u50689 \u50669 \u51060  \u50724 \u55176 \u47140  \u44277 \u46041 \u52404 \u51032  \u48376 \u51656 \u51201  \u44032 \u52824 \u47484  \u46300 \u47084 \u45240 \u45796 . \u44288 \u44228 , \u49888 \u47280 , \u46028 \u48388 , \u51221 \u49436 \u51201  \u50672 \u45824  \'97 \u51060 \u44163 \u46308 \u51008  \u51088 \u46041 \u54868 \u46104 \u51648  \u50506 \u45716 \u45796 . \u45432 \u51064  \u46028 \u48388 \u50640 \u49436  AI\u44032  \u54876 \u47141  \u51669 \u54980 \u47484  \u47784 \u45768 \u53552 \u47553 \u54624  \u49688  \u51080 \u51648 \u47564 , \u49552 \u51012  \u51105 \u50500 \u51452 \u45716  \u44163 \u51008  \u49324 \u46988 \u47564  \u54624  \u49688  \u51080 \u45796 . \u50500 \u51060 \u51032  \u44368 \u50977 \u50640 \u49436  AI\u44032  \u47582 \u52644 \u54805  \u54617 \u49845  \u51088 \u47308 \u47484  \u51228 \u44277 \u54624  \u49688  \u51080 \u51648 \u47564 , \u51340 \u51208 \u54620  \u50500 \u51060 \u47484  \u44201 \u47140 \u54616 \u45716  \u44163 \u51008  \u49324 \u46988 \u51032  \u47787 \u51060 \u45796 . AI\u44032  \u54952 \u50984 \u51032  \u50689 \u50669 \u51012  \u44032 \u51256 \u44040 \u49688 \u47197 , \u51064 \u44036  \u44256 \u50976 \u51032  \u44288 \u44228 \u51201  \u50669 \u54624 \u51060  \u50724 \u55176 \u47140  \u47749 \u54869 \u54644 \u51652 \u45796 .\
\
\uc0\u44060 \u51064 \u44284  \u44277 \u46041 \u52404 \u51032  \u44288 \u44228 \u44032  \u51116 \u54200 \u46108 \u45796 \u45716  \u44163 \u51008 , \u44277 \u46041 \u52404 \u44032  \u49324 \u46972 \u51652 \u45796 \u45716  \u46907 \u51060  \u50500 \u45768 \u45796 . \u44277 \u46041 \u52404 \u50640  \u45824 \u54620  \u44428 \u54620  \u50948 \u51076 \u51032  \u48276 \u50948 \u50752  \u48169 \u49885 \u51060  \u48148 \u45072 \u45796 \u45716  \u46907 \u51060 \u45796 . \u51032 \u51316  \u44592 \u48152 \u51032  \u50948 \u51076 \u50640 \u49436  \u49440 \u53469  \u44592 \u48152 \u51032  \u50948 \u51076 \u51004 \u47196 , \u54252 \u44292 \u51201  \u50948 \u51076 \u50640 \u49436  \u50689 \u50669 \u48324  \u50948 \u51076 \u51004 \u47196  \u51204 \u54872 \u46108 \u45796 . \u51060  \u51204 \u54872 \u51008  \u44221 \u51228  \u51656 \u49436 \u51032  \u48320 \u54868 \u50752  \u48516 \u47532 \u54624  \u49688  \u50630 \u45796 . \u44060 \u51064 \u51060  \u49373 \u44228 \u47484  \u50948 \u54644  \u51312 \u51649 \u50640  \u51333 \u49549 \u46112  \u54596 \u50836 \u44032  \u51460 \u50612 \u46308  \u46412 , \u44277 \u46041 \u52404 \u50640  \u45824 \u54620  \u50948 \u51076 \u51032  \u49457 \u44201 \u46020  \u45804 \u46972 \u51648 \u44592  \u46412 \u47928 \u51060 \u45796 . \u44221 \u51228  \u51656 \u49436 \u51032  \u51656 \u47928 \u50640  \u47676 \u51200  \u45813 \u54644 \u50556  \u54620 \u45796 .\
\
\
\
\
4\uc0\u51109 : \u44221 \u51228  \u51656 \u49436 \u51032  \u51204 \u54872  \'97 \u49884 \u51109 \u51008  \u51088 \u50672 \u51060  \u50500 \u45768 \u45796 \
\
\uc0\u50668 \u44592 \u49436  \u54620  \u44152 \u51020  \u47932 \u47084 \u49436 \u50556  \u54620 \u45796 . \u54788 \u51116 \u51032  \u44221 \u51228  \u51656 \u49436  \'97 \u49884 \u51109  \u44032 \u44201 \u50640  \u51032 \u54644  \u51088 \u50896 \u51060  \u48176 \u48516 \u46104 \u44256 , \u45432 \u46041 \u51060  \u49345 \u54408 \u51004 \u47196  \u44144 \u47000 \u46104 \u44256 , \u44060 \u51064 \u51032  \u44032 \u52824 \u44032  \u49884 \u51109 \u50640 \u49436 \u51032  \u44368 \u54872 \u44032 \u52824 \u47196  \u54872 \u50896 \u46104 \u45716  \u52404 \u44228  \'97 \u47484  \u50864 \u47532 \u45716  \u51088 \u50672 \u49828 \u47084 \u50868  \u44163 \u51004 \u47196  \u48155 \u50500 \u46308 \u51060 \u45716  \u45936  \u51061 \u49689 \u54616 \u45796 . \u44536 \u47084 \u45208  \u51060 \u44163 \u51008  \u50669 \u49324 \u51201 \u51004 \u47196  \u44396 \u49457 \u46108  \u51656 \u49436 \u51060 \u51648 , \u51064 \u47448 \u51032  \u48376 \u49457 \u50640 \u49436  \u51088 \u50672 \u48156 \u49373 \u54620  \u44163 \u51060  \u50500 \u45768 \u45796 .\
\
\uc0\u52852 \u47484  \u54260 \u46972 \u45768 (Karl Polanyi)\u45716  1944\u45380  \u12298 \u44144 \u45824 \u54620  \u51204 \u54872 \u12299 \u50640 \u49436  \u51060  \u51216 \u51012  \u47749 \u53132 \u54616 \u44172  \u45436 \u51613 \u54664 \u45796 . \u54260 \u46972 \u45768 \u51032  \u54645 \u49900  \u51452 \u51109 \u51008  \u49464  \u44032 \u51648 \u45796 .\
\
\uc0\u52395 \u51704 , \u51088 \u44592 \u51312 \u51208  \u49884 \u51109 (self-regulating market)\u51008  \u50669 \u49324 \u51201  \u50696 \u50808 \u45796 . \u51064 \u47448  \u50669 \u49324 \u51032  \u45824 \u48512 \u48516 \u50640 \u49436  \u44221 \u51228  \u54876 \u46041 \u51008  \u49324 \u54924 \u51201  \u44288 \u44228 \u50640  '\u48176 \u53468 (embedded)'\u46104 \u50612  \u51080 \u50632 \u45796 . \u54840 \u54812 , \u51116 \u48516 \u48176 , \u44032 \u44228  \u44221 \u50689 \u51060  \u44221 \u51228 \u51032  \u44592 \u48376  \u50896 \u47532 \u50688 \u45796 . \u49884 \u51109 \u51060  \u49324 \u54924 \u47196 \u48512 \u53552  \u48516 \u47532 \u46104 \u50612  \u46021 \u47549 \u51201 \u51064  \u45436 \u47532 \u47196  \u51089 \u46041 \u54616 \u44592  \u49884 \u51089 \u54620  \u44163 \u51008  19\u49464 \u44592  \u50689 \u44397 \u50640 \u49436 \u51032  \u47588 \u50864  \u53945 \u49688 \u54620  \u50669 \u49324 \u51201  \u49324 \u44148 \u51060 \u45796 . \u44536 \u44163 \u51008  \u51064 \u44036  \u48376 \u49457 \u51032  \u48156 \u54788 \u51060  \u50500 \u45768 \u46972  \u44397 \u44032 \u51032  \u51201 \u44537 \u51201 \u51064  \u51077 \u48277 \u44284  \u44053 \u51228 \u50640  \u51032 \u54644  \u51064 \u50948 \u51201 \u51004 \u47196  \u47564 \u46308 \u50612 \u51652  \u44163 \u51060 \u50632 \u45796 .\
\
\uc0\u46168 \u51704 , \u49884 \u51109 \u51060  \u49324 \u54924 \u47196 \u48512 \u53552  \u48516 \u47532 \u46112  \u46412  \u54596 \u50672 \u51201 \u51004 \u47196  \u54028 \u44340 \u44032  \u48156 \u49373 \u54620 \u45796 . \u53664 \u51648 , \u45432 \u46041 , \u54868 \u54224  \'97 \u54260 \u46972 \u45768 \u44032  '\u54728 \u44396 \u51201  \u49345 \u54408 (fictitious commodities)'\u51060 \u46972  \u48512 \u47480  \u44163 \u46308  \'97 \u45716  \u48376 \u47000  \u54032 \u47588 \u47484  \u50948 \u54644  \u49373 \u49328 \u46108  \u49345 \u54408 \u51060  \u50500 \u45768 \u45796 . \u45432 \u46041 \u51008  \u51064 \u44036  \u49334 \u51032  \u54876 \u46041 \u51060 \u44256 , \u53664 \u51648 \u45716  \u51088 \u50672 \u51060 \u47728 , \u54868 \u54224 \u45716  \u44396 \u47588 \u47141 \u51032  \u49345 \u51669 \u51060 \u45796 . \u51060 \u44163 \u46308 \u51012  \u49884 \u51109  \u45436 \u47532 \u50640  \u51333 \u49549 \u49884 \u53412 \u47732 , \u51064 \u44036 \u44284  \u51088 \u50672 \u44284  \u49324 \u54924 \u44032  \u54028 \u44340 \u46108 \u45796 . 19\u49464 \u44592  \u47568 \u44284  20\u49464 \u44592  \u52488 \u51032  \u45432 \u46041  \u50868 \u46041 , \u49324 \u54924 \u48372 \u54744  \u46020 \u51077 , \u54872 \u44221  \u44508 \u51228 \u45716  \u51060  \u54028 \u44340 \u50640  \u45824 \u54620  \u49324 \u54924 \u51032  \u51088 \u44592 \u48372 \u54840  \u50868 \u46041 \u51060 \u50632 \u45796 .\
\
\uc0\u49483 \u51704 , \u49884 \u51109 \u51032  \u54869 \u51109 \u44284  \u49324 \u54924 \u51032  \u51088 \u44592 \u48372 \u54840  \u49324 \u51060 \u51032  \u44596 \u51109  \'97 \u54260 \u46972 \u45768 \u44032  '\u51060 \u51473  \u50868 \u46041 (double movement)'\u51060 \u46972  \u48512 \u47480  \u44163  \'97 \u51060  \u44540 \u45824 \u49324 \u51032  \u46041 \u47141 \u51060 \u45796 . \u49884 \u51109 \u51060  \u54869 \u51109 \u46104 \u47732  \u49324 \u54924 \u44032  \u51200 \u54637 \u54616 \u44256 , \u51200 \u54637 \u51060  \u44284 \u44201 \u54644 \u51648 \u47732  \u54028 \u49884 \u51608 \u51060 \u45208  \u49324 \u54924 \u51452 \u51032  \u44057 \u51008  \u44537 \u45800 \u51201  \u48152 \u51089 \u50857 \u51060  \u45208 \u53440 \u45212 \u45796 . \u46160  \u52264 \u47168  \u49464 \u44228 \u45824 \u51204 \u51008  \u51060  \u44596 \u51109 \u51032  \u54253 \u48156 \u51201  \u44480 \u44208 \u51060 \u50632 \u45796 .\
\
\uc0\u54260 \u46972 \u45768 \u51032  \u48516 \u49437 \u51060  AI \u49884 \u45824 \u50640  \u51473 \u50836 \u54620  \u51060 \u50976 \u45716  \u47749 \u54869 \u54616 \u45796 . \u54788 \u51116 \u51032  \u49884 \u51109  \u44221 \u51228  \u51656 \u49436 \u44032  \u50689 \u49549 \u51201 \u51060 \u51648  \u50506 \u45796 \u45716  \u49324 \u49892 \u51012  \u50669 \u49324 \u51201 \u51004 \u47196  \u54869 \u51064 \u49884 \u53020 \u51452 \u44592  \u46412 \u47928 \u51060 \u45796 . \u49884 \u51109  \u51656 \u49436 \u45716  \u53945 \u51221  \u44592 \u49696 \u51201 \'b7\u49324 \u54924 \u51201  \u51312 \u44148  \u50500 \u47000 \u49436  \u44396 \u49457 \u46108  \u44163 \u51060 \u47728 , \u44536  \u51312 \u44148 \u51060  \u48148 \u45068 \u47732  \u51656 \u49436 \u46020  \u48148 \u45072 \u45796 . AI\u45716  \u48148 \u47196  \u44536  \u51312 \u44148 \u51012  \u44540 \u48376 \u51201 \u51004 \u47196  \u48148 \u44984 \u44256  \u51080 \u45796 .\
\
\uc0\u45432 \u46041 \u51032  \u48320 \u54805 . AI\u44032  \u54952 \u50984 \u49457 \u44284  \u49373 \u49328 \u49457  \u50689 \u50669 \u50640 \u49436  \u51064 \u44036 \u51012  \u45824 \u52404 \u54632 \u50640  \u46384 \u46972 , \u48152 \u48373  \u44032 \u45733 \u54620  \u51089 \u50629 \u51032  \u49884 \u51109  \u44032 \u52824 \u45716  \u54616 \u46973 \u54620 \u45796 . \u49328 \u50629  \u44221 \u51228 \u50640 \u49436  \u45432 \u46041 \u51008  \u44060 \u51064 \u51060  \u49884 \u51109 \u50640  \u52280 \u50668 \u54616 \u45716  \u44144 \u51032  \u50976 \u51068 \u54620  \u53685 \u47196 \u50688 \u45796 . \u45432 \u46041 \u51012  \u54036 \u50500  \u49548 \u46301 \u51012  \u50619 \u44256 , \u44536  \u49548 \u46301 \u51004 \u47196  \u49884 \u51109 \u50640 \u49436  \u51116 \u54868 \u47484  \u44396 \u47588 \u54616 \u45716  \u44163 \u51060  \u44060 \u51064 \u51032  \u44221 \u51228 \u51201  \u51316 \u51116  \u48169 \u49885 \u51060 \u50632 \u45796 . AI\u44032  \u45432 \u46041 \u51032  \u49345 \u45817  \u48512 \u48516 \u51012  \u45824 \u52404 \u54616 \u47732 , \u51060  \u53685 \u47196 \u44032  \u51329 \u50500 \u51652 \u45796 . \u51060 \u44163 \u51008  \u45800 \u49692 \u54620  \u49892 \u50629  \u47928 \u51228 \u44032  \u50500 \u45768 \u45796 . \u44060 \u51064 \u51060  \u44221 \u51228  \u51656 \u49436 \u50640  \u52280 \u50668 \u54616 \u45716  \u44540 \u48376 \u51201  \u48169 \u49885 \u51032  \u48320 \u54868 \u45796 .\
\
\uc0\u44032 \u52824 \u51032  \u51116 \u54200 . \u48152 \u47732 , \u44288 \u44228 , \u49888 \u47280 , \u47589 \u46973 \u51201  \u54032 \u45800 , \u52285 \u51032 \u51201  \u51333 \u54633 \u51032  \u44032 \u52824 \u45716  \u49345 \u49849 \u54620 \u45796 . \u54924 \u44228  \u48277 \u51064 \u51032  \u45800 \u49692  \u51116 \u47924  \u48516 \u49437 \u51008  AI\u44032  \u45824 \u52404 \u54616 \u44256  \u51080 \u45796 . \u44536 \u47084 \u45208  \u53364 \u46972 \u51060 \u50616 \u53944 \u51032  \u48520 \u50504 \u51012  \u46307 \u44256 , \u49888 \u47280 \u47484  \u49939 \u44256 , \u48373 \u51105 \u54620  \u47589 \u46973 \u51012  \u54644 \u49437 \u54616 \u45716  \u51068 \u51008  \u50668 \u51204 \u55176  \u49324 \u46988 \u51060  \u54620 \u45796 . \u53076 \u46300 \u51032  \u45824 \u48512 \u48516 \u51012  AI\u44032  \u49373 \u49457 \u54616 \u45716  \u49884 \u45824 \u50640 , \u47924 \u50631 \u51012  \u47564 \u46308 \u51648  \u54032 \u45800 \u54616 \u44256  \u50780  \u47564 \u46300 \u45716 \u51648  \u49444 \u47749 \u54616 \u45716  \u51068 \u51032  \u44032 \u52824 \u44032  \u45458 \u50500 \u51652 \u45796 . \u49884 \u51109 \u51060  \u44032 \u44201 \u51004 \u47196  \u54872 \u50896 \u54624  \u49688  \u50630 \u45716  \u44032 \u52824 \u46308 \u51060  \u44221 \u51228 \u51032  \u51473 \u49900 \u51004 \u47196  \u51060 \u46041 \u54616 \u44256  \u51080 \u45796 .\
\
\uc0\u44508 \u47784 \u51032  \u54644 \u52404 . \u49328 \u50629  \u44221 \u51228 \u51032  \u54952 \u50984 \u49457 \u51008  \u44508 \u47784 \u50640 \u49436  \u45208 \u50772 \u45796 . \u45824 \u47049  \u49373 \u49328 , \u45824 \u47049  \u50976 \u53685 , \u45824 \u54805  \u51312 \u51649 \u51060  \u44221 \u51228 \u51201  \u50864 \u50948 \u47484  \u48372 \u51109 \u54664 \u45796 . AI\u45716  \u51060  \u44277 \u49885 \u51012  \u46244 \u51665 \u45716 \u45796 . \u49548 \u44508 \u47784  \u45800 \u50948 \u44032  \u45824 \u44508 \u47784  \u51312 \u51649 \u44284  \u46041 \u46321 \u54620  \u49373 \u49328 \u49457 \u51012  \u44032 \u51656  \u49688  \u51080 \u44172  \u46104 \u47732 , \u51312 \u51649 \u51032  \u51316 \u51116  \u51060 \u50976 \u44032  \u51116 \u51221 \u51032 \u46108 \u45796 . 1\u51064  \u44592 \u50629 \u51060  100\u51064  \u44592 \u50629 \u51032  \u49328 \u52636 \u47932 \u50640  \u54596 \u51201 \u54616 \u45716  \u54872 \u44221 \u50640 \u49436 , \u44592 \u50629 \u51060 \u46972 \u45716  \u54805 \u53468  \u51088 \u52404 \u44032  \u48320 \u54805 \u46108 \u45796 . \u51060 \u44163 \u51008  \u45768 \u52824  \u47560 \u53011 \u51032  \u54869 \u51109 \u51060 \u44592 \u46020  \u54616 \u45796 . \u54620  \u49324 \u46988 \u51012  \u50948 \u54620  \u47582 \u52644 \u54805  \u51228 \u54408 \u44284  \u49436 \u48708 \u49828 \u44032  \u44221 \u51228 \u51201 \u51004 \u47196  \u49457 \u47549  \u44032 \u45733 \u54644 \u51648 \u47732 , \u45824 \u47049  \u49373 \u49328  \u51473 \u49900 \u51032  \u49884 \u51109  \u44396 \u51312 \u44032  \u45796 \u48320 \u54868 \u46108 \u45796 .\
\
\uc0\u48176 \u53468 \u51032  \u54924 \u48373  \u44032 \u45733 \u49457 . \u54260 \u46972 \u45768 \u51032  \u50616 \u50612 \u47196  \u47568 \u54616 \u47732 , AI \u49884 \u45824 \u50640  \u44221 \u51228 \u44032  \u45796 \u49884  \u49324 \u54924 \u50640  '\u48176 \u53468 '\u46112  \u44032 \u45733 \u49457 \u51060  \u50676 \u47536 \u45796 . \u49884 \u51109  \u44032 \u44201 \u51060  \u50500 \u45772  \u44288 \u44228 \u50752  \u47589 \u46973 \u51060  \u44221 \u51228 \u51201  \u44032 \u52824 \u51032  \u44592 \u51456 \u51060  \u46104 \u44256 , \u45824 \u44508 \u47784  \u51312 \u51649  \u45824 \u49888  \u49548 \u44508 \u47784  \u44277 \u46041 \u52404 \u44032  \u44221 \u51228  \u54876 \u46041 \u51032  \u45800 \u50948 \u44032  \u46104 \u45716  \u44396 \u51312 \u45716 , \u49884 \u51109 \u51060  \u49324 \u54924 \u47196 \u48512 \u53552  \u48516 \u47532 \u46104 \u44592  \u51060 \u51204 \u51032  \u44221 \u51228  \u50896 \u47532 \u50752  \u50976 \u49324 \u54620  \u51216 \u51060  \u51080 \u45796 . \u47932 \u47200  \u46041 \u51068 \u54620  \u54924 \u44480 \u45716  \u50500 \u45768 \u45796 . \u44592 \u49696 \u51201  \u51312 \u44148 \u51060  \u51204 \u54784  \u45796 \u47476 \u44592  \u46412 \u47928 \u51060 \u45796 . \u44536 \u47084 \u45208  \u48169 \u54693 \u51008  \u50976 \u49324 \u54616 \u45796 . \u44221 \u51228 \u44032  \u51064 \u44036 \u51032  \u49334 \u51004 \u47196 \u48512 \u53552  \u46021 \u47549 \u46108  \u52628 \u49345 \u51201  \u47700 \u52964 \u45768 \u51608 \u51060  \u50500 \u45768 \u46972 , \u51064 \u44036 \u51032  \u44288 \u44228 \u50752  \u54596 \u50836 \u50640  \u48152 \u51025 \u54616 \u45716  \u52404 \u44228 \u47196  \u51116 \u44396 \u49457 \u46112  \u44032 \u45733 \u49457 \u51060 \u45796 .\
\
\uc0\u51060  \u51204 \u54872 \u51008  \u44592 \u51316  \u51656 \u49436 \u51032  \u49688 \u54812 \u51088 \u50640 \u44172 \u45716  \u50948 \u54801 \u51060 \u45796 . \u49328 \u50629  \u44221 \u51228  \u51656 \u49436  \u50948 \u50640  \u49464 \u50892 \u51652  \u44592 \u50629 , \u44368 \u50977  \u44592 \u44288 , \u44552 \u50997  \u49884 \u49828 \u53596 , \u45432 \u46041  \u49884 \u51109 \u51032  \u51473 \u44060 \u51088 \u46308 \u51008  \u51088 \u49888 \u51032  \u51316 \u51116  \u44592 \u48152 \u51060  \u55124 \u46308 \u47532 \u45716  \u44163 \u51012  \u44221 \u54744 \u54620 \u45796 . \u44536 \u47532 \u44256  \u50669 \u49324 \u44032  \u48152 \u48373 \u51201 \u51004 \u47196  \u48372 \u50668 \u51452 \u46319 , \u44592 \u51316  \u51656 \u49436 \u51032  \u49688 \u54812 \u51088 \u46308 \u51008  \u51204 \u54872 \u50640  \u51200 \u54637 \u54620 \u45796 . \u51060  \u51200 \u54637 \u51060  \u50620 \u47560 \u45208  \u44201 \u47148 \u54616 \u44256  \u50620 \u47560 \u45208  \u50724 \u47000  \u51648 \u49549 \u46104 \u45712 \u45264 \u44032 , \u51204 \u54872 \u51060  \u51652 \u54868 \u47196  \u45149 \u45208 \u45712 \u45264  \u54785 \u47749 \u51004 \u47196  \u45149 \u45208 \u45712 \u45264 \u47484  \u44208 \u51221 \u54620 \u45796 .\
\
\
\
\
5\uc0\u51109 : \u49324 \u54924  \u51656 \u49436 \u51032  \u51204 \u54872  \'97 \u44221 \u51228 \u50640 \u49436  \u51221 \u52824 \u47196 \
\
\uc0\u44221 \u51228  \u51656 \u49436 \u51032  \u48320 \u54868 \u45716  \u51652 \u44277 \u50640 \u49436  \u51068 \u50612 \u45208 \u51648  \u50506 \u45716 \u45796 . \u44221 \u51228  \u51656 \u49436 \u44032  \u48148 \u45068 \u47732  \u44536  \u50948 \u50640  \u49464 \u50892 \u51652  \u51221 \u52824  \u51656 \u49436 \u46020  \u48148 \u45072 \u45796 . \u50669 \u49324 \u50640 \u49436  \u51060  \u49692 \u49436 \u45716  \u51068 \u44288 \u46104 \u50632 \u45796 .\
\
\uc0\u51088 \u48376 \u51452 \u51032 \u44032  \u47676 \u51200  \u45208 \u50772 \u44256  \u48124 \u51452 \u51452 \u51032 \u44032  \u46244 \u46384 \u46992 \u45796 . \u49884 \u51109  \u44221 \u51228 \u44032  \u48393 \u44148  \u44221 \u51228 \u47484  \u45824 \u52404 \u54616 \u47732 \u49436 , \u44221 \u51228 \u51201  \u50669 \u47049 \u51012  \u44054 \u52632  \u49352 \u47196 \u50868  \u44228 \u52789  \'97 \u48512 \u47476 \u51452 \u50500 \u51648  \'97 \u51060  \u51221 \u52824 \u51201  \u48156 \u50616 \u44428 \u51012  \u50836 \u44396 \u54664 \u45796 . \u50689 \u44397 \u51032  1832\u45380  \u49440 \u44144 \u48277  \u44060 \u51221 , \u54532 \u46993 \u49828 \u51032  \u49884 \u48124  \u54785 \u47749 , \u48120 \u44397 \u51032  \u44148 \u44397  \'97 \u51060  \u47784 \u46304  \u51221 \u52824 \u51201  \u51204 \u54872 \u51032  \u48176 \u54980 \u50640 \u45716  \u44221 \u51228  \u51656 \u49436 \u51032  \u49440 \u54665 \u51201  \u48320 \u54868 \u44032  \u51080 \u50632 \u45796 . \u51088 \u48376 \u51452 \u51032 \u51201  \u44221 \u51228  \u51656 \u49436 \u50640 \u49436  \u50669 \u47049 \u51012  \u54869 \u48372 \u54620  \u44060 \u51064 \u46308 \u51060  \u44592 \u51316  \u51221 \u52824  \u51656 \u49436 \u51032  \u48320 \u44221 \u51012  \u50836 \u44396 \u54620  \u44163 \u51060 \u45796 .\
\
AI \uc0\u49884 \u45824 \u50640 \u46020  \u44057 \u51008  \u49692 \u49436 \u44032  \u51089 \u46041 \u54620 \u45796 . \u44221 \u51228 \u51201  \u50669 \u47049 \u51060  \u44060 \u51064 \u50640 \u44172  \u51060 \u46041 \u54616 \u47732 , \u51221 \u52824 \u51201  \u52280 \u50668 \u50640  \u45824 \u54620  \u50836 \u44396 \u46020  \u45804 \u46972 \u51652 \u45796 . \u51221 \u48372 \u50752  \u54032 \u45800  \u50669 \u47049 \u51012  \u44054 \u52632  \u49884 \u48124 \u51008  \u45824 \u51032 \u48124 \u51452 \u51452 \u51032 \u51032  \u44592 \u48376  \u51204 \u51228  \'97 \u49884 \u48124 \u51060  \u51649 \u51217  \u54032 \u45800 \u54616 \u44592  \u50612 \u47140 \u50868  \u48373 \u51105 \u54620  \u47928 \u51228 \u47484  \u51204 \u47928 \u44032 \u50640 \u44172  \u50948 \u51076 \u54620 \u45796  \'97 \u50640  \u51032 \u47928 \u51012  \u51228 \u44592 \u54616 \u44172  \u46108 \u45796 . \u44060 \u51064 \u51060  AI\u51032  \u46020 \u50880 \u51004 \u47196  \u51221 \u52293 \u51032  \u44540 \u44144 \u47484  \u51649 \u51217  \u48516 \u49437 \u54616 \u44256 , \u50696 \u49328  \u48176 \u48516 \u51032  \u54633 \u47532 \u49457 \u51012  \u51649 \u51217  \u44160 \u53664 \u54624  \u49688  \u51080 \u44172  \u46104 \u47732 , "\u50780  4\u45380 \u50640  \u54620  \u48264  \u53804 \u54364 \u54616 \u45716  \u44163 \u51004 \u47196  \u45149 \u45208 \u50556  \u54616 \u45716 \u44032 ?"\u46972 \u45716  \u51656 \u47928 \u51008  \u48520 \u44032 \u54588 \u54616 \u45796 .\
\
\uc0\u46041 \u49884 \u50640 , \u53804 \u47749 \u49457 \u50640  \u45824 \u54620  \u50836 \u44396 \u44032  \u45458 \u50500 \u51652 \u45796 . AI\u45716  \u51221 \u48512 \u51032  \u51221 \u48372  \u48708 \u45824 \u52845 \u51012  \u54644 \u49548 \u54616 \u45716  \u46020 \u44396 \u51060 \u44592 \u46020  \u54616 \u45796 . \u51221 \u52293  \u44208 \u51221  \u44284 \u51221 \u51060  AI\u47484  \u53685 \u54644  \u49884 \u48044 \u47112 \u51060 \u49496 \u46104 \u44256  \u44160 \u51613 \u46112  \u49688  \u51080 \u45796 \u47732 , \u49884 \u48124 \u51008  \u44536  \u44284 \u51221 \u51032  \u44277 \u44060 \u47484  \u50836 \u44396 \u54624  \u44163 \u51060 \u45796 . \u51221 \u48372 \u51032  \u48708 \u45824 \u52845 \u50640  \u44592 \u48152 \u54664 \u45912  \u44288 \u47308 \u51228 \u51032  \u51221 \u45817 \u49457 \u51060  \u46020 \u51204 \u48155 \u45716 \u45796 .\
\
\uc0\u44397 \u51228  \u51656 \u49436 \u50640 \u49436 \u46020  \u51204 \u54872 \u51060  \u51068 \u50612 \u45212 \u45796 . AI \u51204 \u54872 \u50640  \u49457 \u44277 \u54620  \u49324 \u54924 \u50752  \u51200 \u54637 \u54616 \u45716  \u49324 \u54924  \u49324 \u51060 \u51032  \u44201 \u52264 \u44032  \u54869 \u45824 \u46104 \u47732 , \u51060 \u44163 \u51008  \u44221 \u51228 \u51201  \u44201 \u52264 \u47484  \u45336 \u50612  \u50504 \u48372 \u51201  \u44201 \u52264 \u44032  \u46108 \u45796 . \u49328 \u50629 \u54785 \u47749 \u44592 \u50640  \u49328 \u50629 \u54868 \u50640  \u49457 \u44277 \u54620  \u50976 \u47101 \u44284  \u44536 \u47111 \u51648  \u47803 \u54620  \u45208 \u47672 \u51648  \u49464 \u44228  \u49324 \u51060 \u50640  \u48156 \u49373 \u54620  \u50669 \u54617 \u51060 , AI \u49884 \u45824 \u50640 \u46020  \u51116 \u54788 \u46112  \u44032 \u45733 \u49457 \u51060  \u51080 \u45796 .\
\
\uc0\u44221 \u51228  \u51656 \u49436 \u51032  \u48320 \u54868 \u44032  \u51221 \u52824  \u51656 \u49436 \u51032  \u48320 \u54868 \u47484  \u52628 \u46041 \u54616 \u44256 , \u44397 \u45236  \u51221 \u52824  \u51656 \u49436 \u51032  \u48320 \u54868 \u44032  \u44397 \u51228  \u51656 \u49436 \u51032  \u51116 \u54200 \u51004 \u47196  \u51060 \u50612 \u51652 \u45796 . \u51060  \u50672 \u49604 \u44032  \u50620 \u47560 \u45208  \u54217 \u54868 \u47213 \u44172  \u51652 \u54665 \u46104 \u45712 \u45264 \u45716  \u51088 \u46041 \u51004 \u47196  \u44208 \u51221 \u46104 \u51648  \u50506 \u45716 \u45796 . \u50669 \u49324 \u45716  \u54217 \u54868 \u47196 \u50868  \u51204 \u54872 \u44284  \u54028 \u44340 \u51201 \u51064  \u51204 \u54872  \u50577 \u51901 \u51032  \u49324 \u47168 \u47484  \u47784 \u46160  \u44054 \u44256  \u51080 \u45796 . \u45796 \u51020  \u51109 \u50640 \u49436 \u45716  \u54028 \u44340 \u51201  \u44221 \u47196 \u51032  \u50948 \u54744 \u51012  \u44396 \u52404 \u51201 \u51004 \u47196  \u44160 \u53664 \u54620 \u45796 .\
\
\
\
\
6\uc0\u51109 : \u50948 \u54744 \u51032  \u51648 \u54805  \'97 \u44060 \u51064 \u50640 \u49436  \u49464 \u44228 \u44620 \u51648 \
\
\uc0\u51060  \u51204 \u54872 \u51008  \u51088 \u46041 \u51004 \u47196  \u54217 \u54868 \u47213 \u44172  \u51652 \u54665 \u46104 \u51648  \u50506 \u45716 \u45796 . AI \u49884 \u45824 \u51032  \u50948 \u54744 \u51012  \u45436 \u54624  \u46412 , \u50612 \u46500  \u50948 \u54744 \u51012  \u49440 \u53469 \u54664 \u45716 \u51648 \u49104  \u50500 \u45768 \u46972  \u50780  \u44536  \u50948 \u54744 \u51012  \u49440 \u53469 \u54664 \u45716 \u51648 \u44032  \u51473 \u50836 \u54616 \u45796 . \u49688 \u48177  \u44032 \u51648  \u44592 \u49696 \u51201  \u50948 \u54744 \u51012  \u45208 \u50676 \u54616 \u45716  \u44163 \u51008  \u50612 \u47157 \u51648  \u50506 \u45796 . \u44536 \u47084 \u45208  \u47784 \u46304  \u50948 \u54744 \u51060  \u46041 \u46321 \u54616 \u51648 \u45716  \u50506 \u45796 . \u49440 \u48324 \u51032  \u44592 \u51456 \u51060  \u54596 \u50836 \u54616 \u45796 .\
\
\uc0\u50864 \u47532 \u44032  \u51201 \u50857 \u54616 \u45716  \u44592 \u51456 \u51008  \u46160  \u44032 \u51648 \u45796 .\
\
\uc0\u44592 \u51456  1: \u46028 \u51060 \u53420  \u49688  \u50630 \u45716  \u54028 \u44397 . \u54645 \u47924 \u44592 \u44032  \u54869 \u49328 \u46108  \u49464 \u44228 \u50640 \u49436  \u54645 \u51204 \u51137 \u51060  \u54620  \u48264  \u51068 \u50612 \u45208 \u47732 , \u46104 \u46028 \u47540  \u49688  \u50630 \u45796 . AI \u49884 \u45824 \u50640  \u51060 \u50640  \u54644 \u45817 \u54616 \u45716  \u50948 \u54744 \u51060  \u51316 \u51116 \u54616 \u45716 \u44032 ? \u51316 \u51116 \u54620 \u45796 .\
\
\uc0\u44592 \u51456  2: \u44277 \u46041 \u52404 \u51032  \u54644 \u52404 . \u49324 \u54924 \u44032  \u44592 \u45733 \u54616 \u44592  \u50948 \u54620  \u52572 \u49548 \u54620 \u51032  \u49888 \u47280 \u50752  \u50672 \u45824 \u44032  \u54028 \u44340 \u46104 \u45716  \u50948 \u54744 \u51060 \u45796 . \u45236 \u51204 \u44620 \u51648  \u44032 \u51648  \u50506 \u45908 \u46972 \u46020 , \u44396 \u49457 \u50896 \u46308 \u51060  \u49436 \u47196 \u47484  \u51201 \u51004 \u47196  \u51064 \u49885 \u54616 \u45716  \u49688 \u51456 \u50640  \u51060 \u47476 \u47732  \u44277 \u46041 \u52404 \u45716  \u44592 \u45733 \u51012  \u49345 \u49892 \u54620 \u45796 .\
\
\uc0\u51060  \u46160  \u44592 \u51456 \u51012  \u51201 \u50857 \u54616 \u50668 , \u50948 \u54744 \u51012  \u44060 \u51064  \u8594  \u44277 \u46041 \u52404  \u8594  \u44397 \u44032  \u8594  \u49464 \u44228 \u51032  \u49692 \u49436 \u47196  \u44160 \u53664 \u54620 \u45796 . \u51060  \u49692 \u49436 \u44032  \u51473 \u50836 \u54616 \u45796 . \u50948 \u54744 \u51032  \u52404 \u44048 \u51008  \u44060 \u51064 \u50640 \u49436  \u49884 \u51089 \u46104 \u44592  \u46412 \u47928 \u51060 \u45796 .\
\
\uc0\u44060 \u51064  \u49688 \u51456 \u51032  \u50948 \u54744 . AI\u45716  \u44060 \u51064 \u51032  \u50669 \u47049 \u51012  \u54869 \u51109 \u54616 \u51648 \u47564 , \u46041 \u49884 \u50640  \u44060 \u51064 \u51012  \u49352 \u47196 \u50868  \u52712 \u50557 \u49457 \u50640  \u45432 \u52636 \u49884 \u53416 \u45796 . \u52395 \u51704 , \u51221 \u48372  \u54872 \u44221 \u51032  \u51312 \u51089 \u51060 \u45796 . AI\u44032  \u49373 \u49457 \u54616 \u45716  \u51221 \u48372 \u44032  \u44060 \u51064 \u51032  \u51064 \u49885 \u44284  \u54032 \u45800 \u50640  \u51649 \u51217  \u44060 \u51077 \u54624  \u46412 , \u44060 \u51064 \u51008  \u51088 \u49888 \u51032  \u54032 \u45800 \u51060  \u51088 \u50984 \u51201 \u51064 \u51648  \u51312 \u51089 \u46108  \u44163 \u51064 \u51648  \u44396 \u48324 \u54616 \u44592  \u50612 \u47140 \u50892 \u51652 \u45796 . \u51060 \u44163 \u51008  \u44032 \u51676  \u45684 \u49828  \u52264 \u50896 \u51032  \u47928 \u51228 \u44032  \u50500 \u45768 \u45796 . \u44060 \u51064 \u51032  \u51064 \u51648  \u51088 \u52404 \u44032  \u50808 \u48512 \u50640  \u51032 \u54644  \u49444 \u44228 \u46112  \u49688  \u51080 \u45796 \u45716  \u44540 \u48376 \u51201  \u50948 \u54801 \u51060 \u45796 . \u46168 \u51704 , \u44221 \u51228 \u51201  \u49548 \u50808 \u45796 . AI\u44032  \u44592 \u51316  \u45432 \u46041 \u51032  \u49345 \u45817  \u48512 \u48516 \u51012  \u45824 \u52404 \u54616 \u47732 , \u49884 \u51109 \u50640  \u52280 \u50668 \u54624  \u53685 \u47196 \u47484  \u51075 \u45716  \u44060 \u51064 \u51060  \u48156 \u49373 \u54620 \u45796 . \u51060 \u44163 \u51008  \u49373 \u51316 \u51032  \u47928 \u51228 \u51068  \u49104  \u50500 \u45768 \u46972  \u51221 \u52404 \u49457 \u44284  \u51316 \u50628 \u51032  \u47928 \u51228 \u45796 . \u49328 \u50629 \u54868  \u49884 \u45824 \u50640  \u49892 \u50629 \u51060  \u44060 \u51064 \u51032  \u51088 \u51316 \u44048 \u51012  \u54028 \u44340 \u54620  \u44163 \u52376 \u47100 , AI \u49884 \u45824 \u51032  \u44396 \u51312 \u51201  \u47924 \u50857 \u54868 (structural obsolescence)\u45716  \u44060 \u51064 \u51032  \u49324 \u54924 \u51201  \u51316 \u51116  \u51088 \u52404 \u47484  \u50948 \u54801 \u54620 \u45796 .\
\
\uc0\u44277 \u46041 \u52404  \u49688 \u51456 \u51032  \u50948 \u54744 . \u44060 \u51064  \u49688 \u51456 \u51032  \u50948 \u54744 \u51060  \u51665 \u51201 \u46104 \u47732  \u44277 \u46041 \u52404 \u51032  \u44208 \u49549 \u51060  \u54644 \u52404 \u46108 \u45796 . AI\u50640  \u51032 \u54644  \u52572 \u51201 \u54868 \u46108  \u51221 \u48372  \u54872 \u44221 \u51008  \u44396 \u49457 \u50896 \u46308 \u51012  \u49436 \u47196  \u45796 \u47480  \u54788 \u49892  \u50504 \u50640  \u44032 \u46164 \u45796 . \u44057 \u51008  \u49324 \u44148 \u51012  \u46160 \u44256  \u50756 \u51204 \u55176  \u45796 \u47480  \u49324 \u49892  \u51064 \u49885 \u51012  \u44032 \u51652  \u51665 \u45800 \u46308 \u51060  \u54805 \u49457 \u46108 \u45796 . \u51060  \u48516 \u50676 \u51008  \u51221 \u52824 \u51201  \u51032 \u44204 \u51032  \u52264 \u51060 \u44032  \u50500 \u45768 \u46972 , \u49324 \u49892  \u51088 \u52404 \u50640  \u45824 \u54620  \u54633 \u51032 \u51032  \u48533 \u44340 \u45796 . \u54260 \u46972 \u45768 \u44032  \u47568 \u54620  \u49324 \u54924 \u51032  \u51088 \u44592 \u48372 \u54840  \u50868 \u46041 \u51008  \u52572 \u49548 \u54620 \u51032  \u44277 \u50976 \u46108  \u54788 \u49892  \u50948 \u50640 \u49436 \u47564  \u44032 \u45733 \u54616 \u45796 . \u44536  \u44277 \u50976 \u46108  \u54788 \u49892 \u51060  \u49324 \u46972 \u51648 \u47732 , \u49324 \u54924 \u51032  \u51088 \u44592 \u48372 \u54840  \u50868 \u46041 \u51008  \u44537 \u45800 \u54868 \u46104 \u44256 , \u54260 \u46972 \u45768 \u44032  \u44221 \u44256 \u54620  \u54028 \u49884 \u51608 \u51201  \u48152 \u51089 \u50857 \u51032  \u50948 \u54744 \u51060  \u52964 \u51652 \u45796 . \u48372 \u49688 \u50752  \u51652 \u48372 \u44032  \u49436 \u47196 \u51032  \u50976 \u53916 \u48652  \u53080 \u53584 \u52768 \u47484  \u51204 \u54784  \u45796 \u47480  \u49464 \u44228 \u47196  \u44221 \u54744 \u54616 \u44256 , \u49345 \u45824 \u47484  \u51201 \u51004 \u47196  \u51064 \u49885 \u54616 \u47728 , \u44417 \u44537 \u51201 \u51004 \u47196  \u47932 \u47532 \u51201  \u54253 \u47141 \u51032  \u51221 \u45817 \u54868 \u47196  \u45208 \u50500 \u44032 \u45716  \u44221 \u47196 \u45716  \u51060 \u48120  \u44288 \u52272 \u46104 \u44256  \u51080 \u45796 .\
\
\uc0\u44397 \u44032  \u49688 \u51456 \u51032  \u50948 \u54744 . \u44397 \u45236 \u51201 \u51004 \u47196 \u45716  \u44592 \u46301 \u44428 \u51032  \u51200 \u54637 \u51060  \u51228 \u46020 \u51201 \u51004 \u47196  \u49688 \u50857 \u46104 \u51648  \u47803 \u54616 \u47732  \u54785 \u47749 \u51060 \u45208  \u45236 \u51204 \u51004 \u47196  \u51060 \u54665 \u54620 \u45796 . \u54532 \u46993 \u49828  \u54785 \u47749 , \u47084 \u49884 \u50500  \u54785 \u47749 , 20\u49464 \u44592  \u54028 \u49884 \u51608 \u51060  \u51060  \u44221 \u47196 \u50688 \u45796 . AI \u49884 \u45824 \u51032  \u50948 \u54744 \u51008  \u51060  \u44221 \u47196 \u51032  \u49549 \u46020 \u44032  \u48736 \u47476 \u45796 \u45716  \u44163 \u51060 \u45796 . \u49328 \u50629 \u54785 \u47749 \u51008  \u49688 \u49901  \u45380 \u50640  \u44152 \u52432  \u51652 \u54665 \u46104 \u50632 \u44592 \u50640 , \u49324 \u54924 \u44032  \u51201 \u51025 \u54616 \u44256  \u51228 \u46020 \u47484  \u51312 \u51221 \u54624  \u49884 \u44036 \u51060  \u51080 \u50632 \u45796 . AI\u45716  \u49688 \u45380  \u50504 \u50640  \u49328 \u50629  \u44396 \u51312 \u47484  \u48148 \u44984 \u44256  \u51080 \u45796 . \u51228 \u46020 \u44032  \u46384 \u46972 \u44032 \u51648  \u47803 \u54616 \u45716  \u49549 \u46020 \u45796 . \u46608 \u54620  AI\u45716  \u44060 \u51064 \u50640 \u44172  \u44284 \u44144 \u50640  \u48520 \u44032 \u45733 \u54664 \u45912  \u49688 \u51456 \u51032  \u54028 \u44340 \u47141 \u51012  \u48512 \u50668 \u54624  \u49688  \u51080 \u45796 . \u52572 \u44540  Anthropic\u51060  \u44060 \u48156 \u54620  \u44256 \u49457 \u45733  \u47784 \u45944 \u51060  24\u45380  \u46108  \u47532 \u45573 \u49828  \u52404 \u44228 \u51032  \u49900 \u44033 \u54620  \u48372 \u50504  \u52712 \u50557 \u51216 \u51012  \u48156 \u44204 \u54620  \u49324 \u47168 \u44032  \u51060 \u47484  \u48372 \u50668 \u51456 \u45796 . \u51060  \u52712 \u50557 \u51216 \u51060  \u50501 \u50857 \u46104 \u50632 \u45796 \u47732  \u51204  \u49464 \u44228  \u47532 \u45573 \u49828  \u44592 \u48152  \u49436 \u48260  \'97 \u51008 \u54665 , \u53364 \u46972 \u50864 \u46300 , \u51221 \u48512  \u51064 \u54532 \u46972  \'97 \u44032  \u46041 \u49884 \u50640  \u44277 \u44201 \u48155 \u51012  \u49688  \u51080 \u50632 \u45796 . 24\u45380 \u44036  \u51064 \u44036 \u51060  \u48156 \u44204 \u54616 \u51648  \u47803 \u54620  \u44163 \u51012  AI\u44032  \u48156 \u44204 \u54664 \u45796 . \u51060  \u49688 \u51456 \u51032  AI\u44032  \u53685 \u51228  \u50630 \u51060  \u54869 \u49328 \u46104 \u47732 , \u49548 \u49688 \u51032  \u44060 \u51064 \u51060 \u45208  \u48708 \u44397 \u44032  \u54665 \u50948 \u51088 \u44032  \u44397 \u44032  \u51064 \u54532 \u46972  \u49688 \u51456 \u51032  \u54028 \u44340 \u47484  \u44032 \u54624  \u49688  \u51080 \u44172  \u46108 \u45796 .\
\
\uc0\u49464 \u44228  \u49688 \u51456 \u51032  \u50948 \u54744 . \u44397 \u44032  \u44036  \u52649 \u46028 \u51060 \u45796 . AI \u51204 \u54872 \u50640  \u49457 \u44277 \u54620  \u44397 \u44032 \u50752  \u49892 \u54056 \u54620  \u44397 \u44032  \u49324 \u51060 \u51032  \u44201 \u52264 \u44032  \u54056 \u44428  \u44221 \u51137 \u51004 \u47196  \u51060 \u50612 \u51652 \u45796 . \u49328 \u50629 \u54868  \u49884 \u45824 \u51032  \u46160  \u52264 \u47168  \u49464 \u44228 \u45824 \u51204 \u51060  \u51060  \u44221 \u47196 \u50688 \u45796 . \u49328 \u50629 \u54868 \u50640  \u46244 \u52376 \u51652  \u46021 \u51068 \u51060  \u50689 \u44397 \u51032  \u54056 \u44428 \u50640  \u46020 \u51204 \u54664 \u44256 , \u49328 \u50629 \u54868 \u50640  \u49457 \u44277 \u54620  \u51068 \u48376 \u51060  \u50500 \u49884 \u50500 \u50640 \u49436 \u51032  \u54077 \u52285 \u51012  \u52628 \u44396 \u54664 \u45796 . AI \u49884 \u45824 \u50640 \u46020  \u50976 \u49324 \u54620  \u50669 \u54617 \u51060  \u51089 \u46041 \u54624  \u49688  \u51080 \u45796 . AI \u54056 \u44428  \u44221 \u51137 \u51008  \u51060 \u48120  \u48120 \u44397 \u44284  \u51473 \u44397  \u49324 \u51060 \u50640 \u49436  \u44032 \u49884 \u54868 \u46104 \u50612  \u51080 \u51004 \u47728 , \u51060  \u44221 \u51137 \u51060  \u44400 \u49324 \u51201  \u52264 \u50896 \u51004 \u47196  \u54869 \u45824 \u46112  \u44032 \u45733 \u49457 \u51012  \u48176 \u51228 \u54624  \u49688  \u50630 \u45796 .\
\
AI \uc0\u51204 \u54872 \u51008  \u51060  \u45348  \u44032 \u51648  \u49688 \u51456 \u51032  \u50948 \u54744 \u51012  \u46041 \u49884 \u50640  \u54876 \u49457 \u54868 \u54624  \u44032 \u45733 \u49457 \u51060  \u51080 \u45796 . \u49549 \u46020 \u44032  \u45796 \u47476 \u45796 . \u49324 \u54924 \u44032  \u51201 \u51025 \u54624  \u49884 \u44036 \u51060  \u50630 \u45796 . \u51060 \u44163 \u51060  \u49324 \u51204 \u51201  \u44144 \u48260 \u45324 \u49828  \u49444 \u44228 \u44032  \u54596 \u50836 \u54620  \u44540 \u48376 \u51201  \u51060 \u50976 \u45796 .\
