7\uc0\u51109 : \u50864 \u47532 \u44032  \u47785 \u54364 \u54616 \u45716  \u48120 \u47000 \
\
\uc0\u50948 \u54744 \u51012  \u51649 \u49884 \u54620  \u54980 \u50640  \u47932 \u50612 \u50556  \u54624  \u51656 \u47928 \u51060  \u51080 \u45796 . \u44536 \u47000 \u49436  \u50612 \u46356 \u47196  \u44032 \u50556  \u54616 \u45716 \u44032 ?\
\
\uc0\u47924 \u51221 \u48512  \u49345 \u53468 \u51032  self-help \u44396 \u51312 \u50640 \u49436  \u48279 \u50612 \u45208 \u45716  \u44163 . \u51204 \u51137 \u51012  \u44145 \u51221 \u54616 \u51648  \u50506 \u50500 \u46020  \u46104 \u45716  \u49334 , \u51204 \u51137 \u51012  \u45824 \u48708 \u54616 \u51648  \u50506 \u50500 \u46020  \u46104 \u45716  \u49334 . \u51060 \u44163 \u51060  \u49464 \u44228  \u49688 \u51456 \u50640 \u49436 \u51032  \u47785 \u54364 \u45796 .\
\
\uc0\u44060 \u51064  \u49688 \u51456 \u50640 \u49436 \u51032  \u47785 \u54364 \u45716 , \u44033 \u51088 \u51032  \u51221 \u52404 \u49457  \'97 \u51116 \u45733 , \u50896 \u54616 \u45716  \u48148  \'97 \u50640  \u47582 \u44172  \u49334 \u51012  \u44984 \u47540  \u49688  \u51080 \u45716  \u44396 \u51312 \u45796 . \u49373 \u51316 \u51012  \u50948 \u54644  \u51088 \u49888 \u51032  \u51221 \u52404 \u49457 \u51012  \u54252 \u44592 \u54616 \u51648  \u50506 \u50500 \u46020  \u46104 \u45716  \u49324 \u54924 . \u49884 \u51109 \u50640 \u49436 \u51032  \u44368 \u54872 \u44032 \u52824 \u47196  \u54872 \u50896 \u46104 \u51648  \u50506 \u45716  \u49334 \u51032  \u44032 \u52824 \u44032  \u51064 \u51221 \u46104 \u45716  \u44221 \u51228  \u51656 \u49436 . 50\u45824 \u50640  \u49352 \u47196 \u50868  \u48176 \u50880 \u51012  \u49884 \u51089 \u54624  \u49688  \u51080 \u44256 , 30\u45824 \u50640  \u49788 \u51012  \u49440 \u53469 \u54624  \u49688  \u51080 \u51004 \u47728 , 70\u45824 \u50640  \u44221 \u54744 \u50640  \u44592 \u48152 \u54620  \u50669 \u54624 \u47196  \u46028 \u50500 \u50732  \u49688  \u51080 \u45716  \u49373 \u50528 \u51452 \u44592 \u51032  \u50976 \u50672 \u49457 .\
\
\uc0\u51060  \u46160  \u44032 \u51648 \u45716  \u48324 \u44060 \u44032  \u50500 \u45768 \u45796 . \u44060 \u51064 \u51060  \u50504 \u51204 \u54616 \u44172  \u51088 \u49888 \u51032  \u49334 \u51012  \u49332  \u49688  \u51080 \u51012  \u46412 , \u44277 \u46041 \u52404 \u50640  \u45824 \u54620  \u44284 \u46020 \u54620  \u44428 \u54620  \u50948 \u51076 \u51032  \u54596 \u50836 \u49457 \u46020  \u51460 \u50612 \u46304 \u45796 . \u44284 \u46020 \u54620  \u44428 \u54620  \u50948 \u51076 \u51060  \u51460 \u50612 \u46308  \u46412 , \u44397 \u44032 \u44032  \u51204 \u51137  \u44592 \u44228 \u47196  \u51204 \u54872 \u46112  \u50948 \u54744 \u46020  \u51460 \u50612 \u46304 \u45796 . \u44060 \u51064 \u51032  \u50504 \u51204 \u44284  \u49464 \u44228 \u51032  \u54217 \u54868 \u45716  \u44057 \u51008  \u44396 \u51312 \u51032  \u50577 \u47732 \u51060 \u45796 .\
\
\uc0\u54260 \u46972 \u45768 \u51032  \u50616 \u50612 \u47196  \u47568 \u54616 \u47732 , \u44221 \u51228 \u44032  \u45796 \u49884  \u49324 \u54924 \u50640  \u48176 \u53468 \u46104 \u45716  \u44163 \u51060 \u45796 . \u49884 \u51109 \u51060  \u49324 \u54924 \u47484  \u51648 \u48176 \u54616 \u45716  \u44163 \u51060  \u50500 \u45768 \u46972 , \u49324 \u54924 \u44032  \u49884 \u51109 \u51012  \u51088 \u49888 \u51032  \u54596 \u50836 \u50640  \u47582 \u44172  \u54876 \u50857 \u54616 \u45716  \u44396 \u51312 \u47196 \u51032  \u51204 \u54872 \u51060 \u45796 . AI\u45716  \u51060  \u51204 \u54872 \u51012  \u44032 \u45733 \u54616 \u44172  \u54616 \u45716  \u44592 \u49696 \u51201  \u51312 \u44148 \u51012  \u51228 \u44277 \u54620 \u45796 . \u44536 \u47084 \u45208  \u44592 \u49696 \u51060  \u51088 \u46041 \u51004 \u47196  \u51339 \u51008  \u44208 \u44284 \u47484  \u47564 \u46308 \u51648 \u45716  \u50506 \u45716 \u45796 . \u49444 \u44228 \u44032  \u54596 \u50836 \u54616 \u45796 .\
\
