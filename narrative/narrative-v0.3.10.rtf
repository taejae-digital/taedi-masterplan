1\uc0\u51109 : \u50669 \u49324 \u51032  \u54056 \u53556  \'97 \u44060 \u51064 \u51060  \u47676 \u51200  \u48148 \u45072 \u45796 \
\
\uc0\u44592 \u49696  \u54785 \u49888 \u51008  \u48152 \u48373 \u51201 \u51004 \u47196  \u44060 \u51064 \u51032  \u50669 \u47049 \u51012  \u54869 \u51109 \u49884 \u53020  \u50772 \u45796 . \u44536 \u47532 \u44256  \u47588 \u48264  \u44057 \u51008  \u49692 \u49436 \u47196  \u49464 \u49345 \u51060  \u48148 \u45068 \u50632 \u45796 .\
\
\uc0\u54645 \u49900  \u44277 \u49885 :\
\uc0\u44592 \u49696  \u8594  \u44060 \u51064  \u50669 \u47049  \u54869 \u51109  \u8594  \u51088 \u50976 \'b7\u52293 \u51076  \u48276 \u50948  \u54869 \u51109  \u8594  \u44277 \u46041 \u52404  \u51656 \u49436  \u51116 \u54200  \u8594  \u44221 \u51228  \u51656 \u49436  \u51116 \u54805 \u49457  \u8594  \u51221 \u52824  \u51656 \u49436  \u51116 \u54805 \u49457 \
\
\uc0\u45453 \u50629  \u44592 \u49696 \u51008  \u49885 \u47049  \u49373 \u49328 \u51012  \u44060 \u51064  \u45800 \u50948 \u47196  \u44032 \u45733 \u54616 \u44172  \u54664 \u45796 . \u51081 \u50668 \u44032  \u49373 \u44592 \u51088  \u52629 \u51201 \u51060  \u49884 \u51089 \u46104 \u50632 \u44256 , \u52629 \u51201 \u51008  \u48516 \u50629 \u51012 , \u48516 \u50629 \u51008  \u44228 \u44553 \u51012  \u47564 \u46308 \u50632 \u45796 . \u49688 \u47157 -\u52292 \u51665  \u49884 \u45824 \u51032  \u54217 \u46321 \u54620  \u47924 \u47532 \u44032  \u44228 \u52789 \u54868 \u46108  \u52492 \u46973 \u51004 \u47196  \u48148 \u45072  \u44163 \u51008  \u46020 \u45909 \u51201  \u49440 \u53469 \u51060  \u50500 \u45768 \u46972  \u50669 \u47049  \u54869 \u51109 \u51032  \u44396 \u51312 \u51201  \u44480 \u44208 \u51060 \u50632 \u45796 .\
\
\uc0\u51064 \u49604 \u49696 \u51008  \u51648 \u49885  \u51217 \u44540 \u51032  \u48708 \u50857 \u51012  \u44537 \u51201 \u51004 \u47196  \u45230 \u52628 \u50632 \u45796 . \u49457 \u44221 \u51060  \u46972 \u54004 \u50612  \u46021 \u51216 \u50640 \u49436  \u54400 \u47140 \u45208 \u51088  \u51333 \u44368 \u51201  \u44428 \u50948 \u44032  \u55124 \u46308 \u47160 \u44256 , \u51648 \u49885 \u51060  \u45824 \u54617  \u48150 \u51004 \u47196  \u54140 \u51648 \u51088  \u44480 \u51313 \u51032  \u51221 \u48372  \u46021 \u51216 \u51060  \u54644 \u52404 \u46104 \u50632 \u45796 . \u47336 \u53552 \u51032  95\u44060  \u51312 \u54637 \u51008  \u51064 \u49604 \u44592  \u50630 \u51060 \u45716  \u48708 \u53584 \u48288 \u47476 \u53356  \u44368 \u54924  \u47928  \u50526 \u50640 \u49436  \u45149 \u45228 \u51012  \u44163 \u51060 \u45796 . \u44060 \u51064 \u51060  \u51649 \u51217  \u53581 \u49828 \u53944 \u47484  \u51069 \u44256  \u54032 \u45800 \u54624  \u49688  \u51080 \u44172  \u46108  \u49692 \u44036 , \u51473 \u49464 \u51032  \u50948 \u44228  \u44396 \u51312 \u45716  \u51221 \u45817 \u49457 \u51012  \u51075 \u44592  \u49884 \u51089 \u54664 \u45796 .\
\
\uc0\u49328 \u50629  \u44592 \u44228 \u45716  \u47932 \u51201  \u49373 \u49328 \u51012  \u44060 \u51064  \u51088 \u48376 \u50640  \u44060 \u48169 \u54664 \u45796 . \u48393 \u44148  \u50689 \u51452 \u51032  \u53664 \u51648 \u44032  \u50500 \u45768 \u46972  \u44277 \u51109 \u51452 \u51032  \u44592 \u44228 \u44032  \u48512 \u51032  \u50896 \u52380 \u51060  \u46104 \u47732 \u49436 , \u44221 \u51228  \u51656 \u49436 \u44032  \u47676 \u51200  \u48148 \u45068 \u50632 \u44256  \u51221 \u52824  \u51656 \u49436 \u44032  \u46244 \u46384 \u46992 \u45796 . \u50689 \u44397 \u50640 \u49436  \u49440 \u44144 \u44428 \u51060  \u51216 \u51652 \u51201 \u51004 \u47196  \u54869 \u45824 \u46108  \u44163 \u51008  \u49328 \u50629  \u51088 \u48376 \u44032 \u50752  \u45432 \u46041 \u51088 \u44032  \u44592 \u51316  \u51221 \u52824  \u51656 \u49436  \u50504 \u50640 \u49436  \u47785 \u49548 \u47532 \u47484  \u45236 \u44592  \u49884 \u51089 \u54664 \u44592  \u46412 \u47928 \u51060 \u45796 . \u44221 \u51228 \u51201  \u50669 \u47049 \u51032  \u54869 \u51109 \u51060  \u51221 \u52824 \u51201  \u44428 \u47532 \u51032  \u54869 \u51109 \u50640  \u49440 \u54665 \u54664 \u45796 .\
\
\uc0\u51064 \u53552 \u45367 \u51008  \u51221 \u48372  \u50976 \u53685 \u51032  \u48708 \u45824 \u52845 \u49457 \u51012  \u50756 \u54868 \u54664 \u45796 . \u50616 \u47200 \u49324 , \u52636 \u54032 \u49324 , \u48169 \u49569 \u44397 \u51060  \u46021 \u51216 \u54664 \u45912  \u51221 \u48372  \u52292 \u45328 \u51060  \u44060 \u48169 \u46104 \u47732 \u49436 , \u44060 \u51064 \u51008  \u49688 \u50857 \u51088 \u50640 \u49436  \u49373 \u49328 \u51088 \u47196  \u51204 \u54872 \u46104 \u50632 \u45796 . \u50500 \u46989 \u51032  \u48388 \u50640 \u49436  \u49548 \u49500  \u48120 \u46356 \u50612 \u44032  \u54620  \u50669 \u54624 \u51008  \u51064 \u49604 \u49696 \u51060  \u51333 \u44368 \u44060 \u54785 \u50640 \u49436  \u54620  \u50669 \u54624 \u51032  \u46356 \u51648 \u53560 \u54032 \u51060 \u50632 \u45796 .\
\
AI\uc0\u45716  \u51060  \u50672 \u51109 \u49440 \u50640  \u51080 \u45796 . \u45800 , \u51060 \u48264 \u50640  \u54869 \u51109 \u46104 \u45716  \u50669 \u47049 \u51008  \u54032 \u45800 \u44284  \u52628 \u47200 \u51060 \u45796 . \u51060  \u51216 \u51060  \u44208 \u51221 \u51201 \u51004 \u47196  \u45796 \u47476 \u45796 . \u51060 \u51204 \u51032  \u44592 \u49696 \u46308 \u51060  \u54869 \u51109 \u54620  \u44163 \u51008  \u49888 \u52404 \u51201  \u45432 \u46041 \u47141 , \u51221 \u48372  \u51217 \u44540 \u49457 , \u49548 \u53685  \u48276 \u50948 \u50688 \u45796 . \u54032 \u45800  \u45733 \u47141 \u51008  \u44148 \u46300 \u47532 \u51648  \u47803 \u54664 \u45796 . \u54032 \u45800 \u51008  \u51648 \u44552 \u44620 \u51648  \u47784 \u46304  \u50948 \u44228  \u44396 \u51312 \u51032  \u54645 \u49900  \u51221 \u45817 \u49457 \u51060 \u50632 \u45796 . \u51204 \u47928 \u44032 \u51032  \u44428 \u50948 , \u44288 \u47532 \u51088 \u51032  \u51316 \u51116  \u51060 \u50976 , \u51032 \u49324 \u44208 \u51221 \u51088 \u51032  \u51648 \u50948  \'97 \u51060  \u47784 \u46304  \u44163 \u51008  \u51221 \u48372 \u50752  \u54032 \u45800 \u51032  \u48708 \u45824 \u52845 \u49457  \u50948 \u50640  \u49464 \u50892 \u51256  \u51080 \u50632 \u45796 . AI\u45716  \u48148 \u47196  \u44536  \u48708 \u45824 \u52845 \u51012  \u54644 \u49548 \u54616 \u44256  \u51080 \u45796 .\
\
\uc0\u44536 \u47084 \u45208  \u54788 \u51116 \u51032  AI \u45436 \u51032  \u45824 \u48512 \u48516 \u51008  \u51060  \u49692 \u49436 \u47484  \u44148 \u45320 \u46836 \u45796 . \u44592 \u49696 \u51060  \u44060 \u51064 \u51012  \u50612 \u46523 \u44172  \u48148 \u44984 \u45716 \u51648 , \u48148 \u45072  \u44060 \u51064 \u51060  \u44277 \u46041 \u52404 \u50752 \u51032  \u44288 \u44228 \u47484  \u50612 \u46523 \u44172  \u51116 \u54801 \u49345 \u54616 \u45716 \u51648 , \u44536  \u51116 \u54801 \u49345 \u51060  \u44221 \u51228  \u51656 \u49436 \u47484  \u50612 \u46523 \u44172  \u48320 \u54805 \u49884 \u53412 \u45716 \u51648 \u47484  \u47931 \u51648  \u50506 \u44256 , \u44263 \u48148 \u47196  "AI\u47484  \u50612 \u46523 \u44172  \u44508 \u51228 \u54624  \u44163 \u51064 \u44032 "\u47196  \u51649 \u54665 \u54620 \u45796 . \u44221 \u51228  \u51656 \u49436 \u51032  \u54644 \u49437  \u50630 \u51060  \u44144 \u48260 \u45324 \u49828 \u47484  \u45436 \u54616 \u47732 , \u44536  \u44144 \u48260 \u45324 \u49828 \u45716  \u44277 \u51473 \u50640  \u46892 \u45796 . \u47924 \u50631 \u51012  \u50780  \u44508 \u51228 \u54644 \u50556  \u54616 \u45716 \u51648 \u50640  \u45824 \u54620  \u54633 \u51032  \u50630 \u51060  \u47564 \u46308 \u50612 \u51652  \u51228 \u46020 \u45716  \u54788 \u49892 \u51012  \u48152 \u50689 \u54616 \u51648  \u47803 \u54620 \u45796 .\
\
