8\uc0\u51109 : \u50780  \u51648 \u44552 \u51064 \u44032  \'97 \u49444 \u44228 \u44032  \u50526 \u49436 \u47732  \u48708 \u50857 \u51060  \u45230 \u45796 \
\
\uc0\u44144 \u48260 \u45324 \u49828 \u51032  \u50669 \u49324 \u45716  \u46160  \u44032 \u51648  \u44221 \u47196 \u47484  \u48372 \u50668 \u51456 \u45796 .\
\
\uc0\u49324 \u51204  \u49444 \u44228  \u44221 \u47196 : \u54868 \u54617 \u47924 \u44592 \u44552 \u51648 \u54801 \u50557 (CWC)\u44284  \u47788 \u53944 \u47532 \u50732  \u51032 \u51221 \u49436 \u45716  \u47928 \u51228 \u44032  \u53685 \u51228  \u48520 \u45733 \u51060  \u46104 \u44592  \u51204 \u50640  \u44397 \u51228  \u54633 \u51032 \u47484  \u51060 \u45132 \u50612 \u45256 \u45796 . CWC\u45716  \u54868 \u54617 \u47924 \u44592 \u44032  \u45824 \u44508 \u47784 \u47196  \u49324 \u50857 \u46104 \u44592  \u51204 \u50640  \u44552 \u51648  \u52404 \u44228 \u47484  \u44396 \u52629 \u54664 \u44256 , \u47788 \u53944 \u47532 \u50732  \u51032 \u51221 \u49436 \u45716  \u50724 \u51316 \u52789  \u54028 \u44340 \u44032  \u46028 \u51060 \u53420  \u49688  \u50630 \u45716  \u49688 \u51456 \u50640  \u51060 \u47476 \u44592  \u51204 \u50640  \u50896 \u51064  \u47932 \u51656 \u51012  \u44508 \u51228 \u54664 \u45796 . \u51060  \u49324 \u47168 \u46308 \u50640 \u49436  \u44277 \u53685 \u51201 \u51064  \u44163 \u51008 , \u44284 \u54617 \u51201  \u51613 \u44144 \u50752  \u51221 \u52824 \u51201  \u51032 \u51648 \u44032  \u47564 \u45208  \u54588 \u54644 \u44032  \u52572 \u45824 \u54868 \u46104 \u44592  \u51204 \u50640  \u51228 \u46020 \u44032  \u51089 \u46041 \u54664 \u45796 \u45716  \u51216 \u51060 \u45796 .\
\
\uc0\u49324 \u54980  \u48393 \u54633  \u44221 \u47196 : \u54645 \u48708 \u54869 \u49328 \u51312 \u50557 (NPT)\u44284  \u49373 \u47932 \u47924 \u44592 \u44552 \u51648 \u54801 \u50557 (BWC)\u51008  \u51060 \u48120  \u54869 \u49328 \u51060  \u51652 \u54665 \u46108  \u54980 \u50640  \u47564 \u46308 \u50612 \u51276 \u45796 . NPT\u45716  \u54645 \u48372 \u50976 \u44397 \u44284  \u48708 \u48372 \u50976 \u44397  \u49324 \u51060 \u51032  \u48520 \u54217 \u46321 \u54620  \u44396 \u51312 \u47484  \u45236 \u51109 \u54616 \u44256  \u51080 \u51004 \u47728 , BWC\u45716  \u44160 \u51613  \u47700 \u52964 \u45768 \u51608 \u51060  \u50630 \u50612  \u49892 \u54952 \u49457 \u51060  \u51228 \u54620 \u51201 \u51060 \u45796 . \u49324 \u54980 \u50640  \u47564 \u46308 \u50612 \u51652  \u44144 \u48260 \u45324 \u49828 \u45716  \u51060 \u48120  \u54805 \u49457 \u46108  \u51060 \u54644 \u44288 \u44228 \u47484  \u51312 \u51221 \u54644 \u50556  \u54616 \u44592  \u46412 \u47928 \u50640 , \u48376 \u51656 \u51201 \u51004 \u47196  \u48520 \u50756 \u51204 \u54624  \u49688 \u48150 \u50640  \u50630 \u45796 .\
\
AI\uc0\u51032  \u49549 \u46020 \u45716  \u51613 \u44592 \u44592 \u44288 \u44284  \u45796 \u47476 \u45796 . \u51613 \u44592 \u44592 \u44288 \u51008  \u49688 \u49901  \u45380 \u50640  \u44152 \u52432  \u54869 \u49328 \u46104 \u50632 \u45796 . \u44536  \u49884 \u44036  \u46041 \u50504  \u45432 \u46041 \u48277 \u51060  \u47564 \u46308 \u50612 \u51648 \u44256 , \u49324 \u54924 \u48372 \u54744 \u51060  \u49444 \u44228 \u46104 \u44256 , \u44368 \u50977  \u51228 \u46020 \u44032  \u44060 \u54200 \u46104 \u50632 \u45796 . AI\u45716  \u49688 \u45380  \u50504 \u50640  \u49324 \u54924  \u51204 \u48152 \u51012  \u48148 \u44984 \u44256  \u51080 \u45796 . GPT-3\u50640 \u49436  GPT-5\u44620 \u51648 , Claude 3\u50640 \u49436  \u54788 \u51116 \u51032  \u52572 \u49888  \u47784 \u45944 \u44620 \u51648 \u51032  \u48156 \u51204 \u51060  3\u45380  \u50504 \u50640  \u51060 \u47336 \u50612 \u51276 \u45796 . \u51060  \u49549 \u46020 \u50640 \u49436  \u49324 \u54980  \u45824 \u51025 \u51008  \u44396 \u51312 \u51201 \u51004 \u47196  \u48520 \u44032 \u45733 \u54616 \u45796 .\
\
AI \uc0\u47784 \u45944 \u51032  \u50948 \u54744 \u49457 \u51012  \u44060 \u48156 \u51088 \u44032  \u47676 \u51200  \u51077 \u51613 \u54644 \u50556  \u54620 \u45796 \u45716  \u50896 \u52825  \'97 FDA \u47784 \u45944 \u44284  \u50976 \u49324 \u54620  \u49324 \u51204  \u49849 \u51064  \u52404 \u44228  \'97 \u51008  \u51060 \u48120  \u51068 \u48512  \u44592 \u50629 \u50640 \u49436  \u51088 \u48156 \u51201 \u51004 \u47196  \u49892 \u54665 \u46104 \u44256  \u51080 \u45796 . Anthropic\u51060  \u44256 \u49457 \u45733  \u47784 \u45944 \u51032  \u52636 \u49884 \u47484  \u51088 \u52404  \u50504 \u51204 \u49457  \u44160 \u51613 \u51060  \u50756 \u47308 \u46112  \u46412 \u44620 \u51648  \u48372 \u47448 \u54620  \u44163 \u51060  \u44536  \u49324 \u47168 \u45796 . \u44536 \u47084 \u45208  \u54620  \u44592 \u50629 \u51032  \u51088 \u48156 \u51201  \u54665 \u46041 \u51060  \u47784 \u46304  \u44592 \u50629 \u50640  \u51201 \u50857 \u46104 \u47532 \u46972 \u45716  \u48372 \u51109 \u51008  \u50630 \u45796 . \u51088 \u48156 \u51201  \u50980 \u47532 \u51032  \u54620 \u44228 \u44032  \u50668 \u44592 \u50640  \u51080 \u45796 . \u51228 \u46020 \u54868 \u44032  \u54596 \u50836 \u54620  \u51060 \u50976 \u45796 .\
\
Yoshua Bengio\uc0\u44032  \u51060 \u45124 \u45716  \u44397 \u51228  AI \u50504 \u51204  \u45436 \u51032 \u45716  \u51060  \u48169 \u54693 \u50640 \u49436  \u49440 \u46020 \u51201  \u50669 \u54624 \u51012  \u54616 \u44256  \u51080 \u45796 . \u44060 \u48156 \u51088 \u51032  \u51077 \u51613  \u52293 \u51076 \u51012  \u51228 \u46020 \u54868 \u54616 \u47140 \u45716  \u45432 \u47141 , AI \u50948 \u54744  \u54217 \u44032  \u54532 \u47112 \u51076 \u50892 \u53356 \u51032  \u44396 \u52629 , \u44397 \u51228 \u51201  \u54633 \u51032  \u44592 \u48152 \u51032  \u47560 \u47144  \'97 \u51060  \u51089 \u50629 \u46308 \u51060  \u51652 \u54665  \u51473 \u51060 \u45796 . \u50864 \u47532 \u51032  \u44284 \u51228 \u45716  \u51060  \u55120 \u47492 \u44284  \u50612 \u46523 \u44172  \u44057 \u44256  \u50612 \u46523 \u44172  \u45796 \u47480 \u51648 \u47484  \u47749 \u54869 \u55176  \u54616 \u44256 , \u50864 \u47532 \u47564 \u51032  \u44592 \u50668  \u51648 \u51216 \u51012  \u54869 \u48372 \u54616 \u45716  \u44163 \u51060 \u45796 .\
