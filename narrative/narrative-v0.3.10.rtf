\uc0\u51648 \u44552 \u51060  \u47560 \u51648 \u47561  \u52285 \u51060 \u45796 . \u51204 \u54872 \u51060  \u50756 \u49457 \u46108  \u54980  \u44144 \u48260 \u45324 \u49828 \u47484  \u49444 \u44228 \u54616 \u47732  \u51060 \u48120  \u45734 \u45796 . \u49324 \u54980  \u48393 \u54633 \u51008  \u48520 \u50756 \u51204 \u54616 \u44256 , \u48520 \u50756 \u51204 \u54620  \u44144 \u48260 \u45324 \u49828 \u45716  \u44536  \u51088 \u52404 \u47196  \u44040 \u46321 \u51032  \u50896 \u51064 \u51060  \u46108 \u45796 . NPT\u44032  \u54645  \u48372 \u50976 \u44397 \u44284  \u48708 \u48372 \u50976 \u44397  \u49324 \u51060 \u51032  \u44396 \u51312 \u51201  \u48520 \u47564 \u51012  \u45236 \u51109 \u54620  \u44163 \u52376 \u47100 , AI \u44144 \u48260 \u45324 \u49828 \u44032  \u44592 \u49696  \u49440 \u46020 \u44397 \u44284  \u54980 \u48156 \u44397  \u49324 \u51060 \u51032  \u48520 \u54217 \u46321 \u51012  \u44256 \u52265 \u49884 \u53412 \u47732 , \u44144 \u48260 \u45324 \u49828  \u51088 \u52404 \u44032  \u44040 \u46321 \u51032  \u50896 \u52380 \u51060  \u46108 \u45796 .\
